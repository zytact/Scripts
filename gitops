#!/usr/bin/env bash
# gitops — AI-powered git workflow using opencode
# Usage: gitops <commit|branch|pr|auto>

set -euo pipefail

# ── Config ────────────────────────────────────────────────────────────────────
MODEL="${GITOPS_MODEL:-github-copilot/gpt-5.4-mini}"
VARIANT="${GITOPS_VARIANT:-low}"
MAIN_BRANCHES="main master develop"
NO_AI=0

AGENT_SYSTEM_PROMPT='You are a git workflow assistant. Generate concise conventional commit messages, short kebab-case branch names, and clear GitHub PR descriptions in markdown. Output only the requested artifact — no commentary, no explanations.'

# ── Theme ─────────────────────────────────────────────────────────────────────
_query_color_slot() {
  # Query terminal for color slot $1 via OSC 4; echoes #RRGGBB or returns 1 on failure.
  local slot="$1"
  [[ -t 0 && -t 1 ]] || return 1
  local response old_stty
  old_stty="$(stty -g 2>/dev/null)" || return 1
  stty raw -echo min 0 time 2 2>/dev/null || return 1
  printf "\033]4;%d;?\033\\" "$slot" >/dev/tty
  IFS= read -r -s -d $'\a' response </dev/tty 2>/dev/null
  stty "$old_stty" 2>/dev/null
  [[ -z "$response" ]] && return 1
  local r g b
  r="$(printf '%s' "$response" | grep -oP '(?<=rgb:)[0-9a-fA-F]{4}' | sed -n '1p')"
  g="$(printf '%s' "$response" | grep -oP '(?<=rgb:)[0-9a-fA-F]{4}' | sed -n '2p')"
  b="$(printf '%s' "$response" | grep -oP '(?<=rgb:)[0-9a-fA-F]{4}' | sed -n '3p')"
  [[ -z "$r" || -z "$g" || -z "$b" ]] && return 1
  printf '#%s%s%s' "${r:0:2}" "${g:0:2}" "${b:0:2}"
}

_c() {
  # Resolve color: try OSC 4 query, fall back to bare ANSI index (gum accepts both).
  local slot="$1"
  local rgb
  rgb="$(_query_color_slot "$slot" 2>/dev/null)" && echo "$rgb" || echo "$slot"
}
C_INFO="$(_c 4)"
C_SUCCESS="$(_c 2)"
C_ERROR="$(_c 1)"
C_ACCENT="$(_c 5)"
C_BORDER="$(_c 5)"

# ── Helpers ───────────────────────────────────────────────────────────────────
die()  { gum style --foreground "$C_ERROR" "✗ $*" >&2; exit 1; }
info() { gum style --foreground "$C_INFO" "→ $*"; }

require() {
  for cmd in "$@"; do
    command -v "$cmd" &>/dev/null || die "Required command not found: $cmd"
  done
}

run_opencode() {
  # $1 = short instruction (message arg), $2 = large context written to file
  local instruction="$1" context="${2:-}"
  local full_msg="${AGENT_SYSTEM_PROMPT}

${instruction}"
  local result
  if [[ -n "$context" ]]; then
    local ctx_file
    ctx_file="$(mktemp /tmp/gitops-context.XXXXXX)"
    trap 'rm -f "$ctx_file"' RETURN
    printf '%s' "$context" > "$ctx_file"
    result="$(gum spin --spinner dot --title "Thinking…" -- \
      opencode run --model "$MODEL" ${VARIANT:+--variant "$VARIANT"} "$full_msg" -f "$ctx_file")"
  else
    result="$(gum spin --spinner dot --title "Thinking…" -- \
      opencode run --model "$MODEL" ${VARIANT:+--variant "$VARIANT"} "$full_msg")"
  fi
  echo "$result"
}

staged_diff() {
  git diff --cached --stat --diff-filter=ACMRD
  echo "---"
  git diff --cached --diff-filter=ACMRD
}

current_branch() {
  git rev-parse --abbrev-ref HEAD
}

is_main_branch() {
  local branch="$1"
  for b in $MAIN_BRANCHES; do
    [[ "$branch" == "$b" ]] && return 0
  done
  return 1
}

detect_base_branch() {
  local remote_head
  remote_head="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)"
  if [[ -n "$remote_head" ]]; then
    echo "${remote_head##*/}"
    return
  fi
  for b in $MAIN_BRANCHES; do
    git rev-parse --verify "$b" &>/dev/null && echo "$b" && return
  done
  die "Cannot detect base branch. Set GITOPS_BASE explicitly."
}


edit_in_editor() {
  # $1 = file path — caller manages the temp file; editor runs outside any $()
  "${EDITOR:-nano}" "$1" </dev/tty >/dev/tty
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_commit() {
  # Collect unstaged + untracked files
  local unstaged untracked all_files
  unstaged="$(git diff --name-only 2>/dev/null)"
  untracked="$(git ls-files --others --exclude-standard 2>/dev/null)"
  all_files="$(printf '%s\n%s\n' "$unstaged" "$untracked" | sort -u | grep -v '^$' || true)"

  # If everything is already staged, skip the file selector
  if [[ -z "$all_files" ]] && [[ -n "$(git diff --cached --name-only 2>/dev/null)" ]]; then
    info "All changes already staged — skipping file selection."
  elif [[ -n "$all_files" ]]; then
    echo ""
    gum style \
      --foreground "$C_ACCENT" --border-foreground "$C_BORDER" --border rounded \
      --padding "0 1" "Select files to stage  (↑↓ navigate · x toggle · enter confirm)"
    echo ""

    local selected
    selected="$(echo "$all_files" | gum choose --no-limit \
      --header "" \
      --cursor "    " \
      --cursor-prefix "[ ] " \
      --selected-prefix "[x] " \
      --unselected-prefix "[ ] " \
      --height 20)" || die "Staging cancelled."

    if [[ -n "$selected" ]]; then
      echo "$selected" | while read -r file; do
        git add -- "$file"
      done
      local count
      count="$(echo "$selected" | grep -c .)"
      echo ""
      gum style --foreground "$C_SUCCESS" "✔ Staged $count file(s):"
      echo "$selected" | while read -r f; do echo "  + $f"; done
      echo ""
    fi
  fi

  [[ -z "$(git diff --cached --name-only)" ]] && die "No staged changes."

  local diff
  diff="$(staged_diff)"

  local msg
  if [[ "$NO_AI" -eq 1 ]]; then
    echo ""
    msg="$(gum input --placeholder "Commit message (conventional commit format)")"
    [[ -z "$msg" ]] && die "Aborted — empty message."
  else
    info "Generating commit message…"
    msg="$(run_opencode "Generate a conventional commit message for the staged diff in the attached file." "$diff")"
    msg="$(echo "$msg" | sed 's/^[[:space:]]*//' | head -1)"
  fi
  echo ""
  echo "  📝 $msg"
  echo ""

  local action
  action="$(printf 'Accept\nEdit\nAbort' | gum choose --header "Commit message:")"
  case "$action" in
    Accept)
      git commit -m "$msg"
      info "Committed: $msg" ;;
    Edit)
      local tmp_msg
      tmp_msg="$(mktemp /tmp/gitops-commit.XXXXXX)"
      printf '%s' "$msg" > "$tmp_msg"
      edit_in_editor "$tmp_msg"
      msg="$(cat "$tmp_msg")"
      rm -f "$tmp_msg"
      msg="$(echo "$msg" | sed 's/^[[:space:]]*//' | grep -v '^$' | head -1)"
      [[ -z "$msg" ]] && die "Aborted — empty message."
      git commit -m "$msg"
      info "Committed: $msg" ;;
    *) die "Aborted." ;;
  esac
}

cmd_branch() {
  local diff
  diff="$(staged_diff)"
  [[ -z "$(git diff --cached --name-only 2>/dev/null)" ]] && {
    # Fall back to unstaged changes for branch naming context
    diff="$(git diff --stat HEAD 2>/dev/null || echo 'new work')"
  }

  local branch
  if [[ "$NO_AI" -eq 1 ]]; then
    echo ""
    branch="$(gum input --placeholder "Branch name (kebab-case)")"
    [[ -z "$branch" ]] && die "Aborted — empty branch name."
    branch="$(echo "$branch" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
  else
    info "Generating branch name…"
    branch="$(run_opencode "Generate a branch name for the diff in the attached file. Output ONLY the branch name, nothing else." "$diff")"
    branch="$(echo "$branch" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
  fi
  echo ""
  echo "  🌿 $branch"
  echo ""

  if gum confirm "Checkout new branch '$branch'?"; then
    git checkout -b "$branch"
    info "Switched to branch: $branch"
  else
    local custom
    custom="$(gum input --placeholder "Custom branch name (blank to abort)")"
    [[ -z "$custom" ]] && die "Aborted."
    git checkout -b "$custom"
  fi
}

cmd_pr() {
  require gh

  local base_branch current
  current="$(current_branch)"
  base_branch="${GITOPS_BASE:-$(detect_base_branch)}"

  # Gather context: commits ahead of base + their diffs
  local commits diff context
  commits="$(git log "$base_branch".."$current" --oneline 2>/dev/null || echo '(no commits yet)')"
  diff="$(git diff "$base_branch"..."$current" --stat 2>/dev/null || staged_diff)"

  context="Branch: $current → $base_branch

Commits:
$commits

Diff summary:
$diff"

  local body
  if [[ "$NO_AI" -eq 1 ]]; then
    echo ""
    body="$(gum write --placeholder "PR description (markdown)" --width 80 --height 15)"
    [[ -z "$body" ]] && die "Aborted — empty PR body."
  else
    info "Generating PR description…"
    body="$(run_opencode "Generate a GitHub PR description for the branch context in the attached file. Output only the markdown body." "$context")"
  fi

  # Derive title from first commit or generate fresh
  local title
  title="$(git log "$base_branch".."$current" --oneline | tail -1 | sed 's/^[a-f0-9]* //' || echo "$current")"

  echo ""
  gum style \
    --border rounded --border-foreground "$C_BORDER" \
    --padding "0 1" \
    "$(printf 'Title: %s\n\n%s' "$title" "$body")"
  echo ""

  local action
  action="$(printf 'Open PR\nEdit body\nAbort' | gum choose --header "PR ready:")"
  case "$action" in
    "Open PR")
      gh pr create --base "$base_branch" --title "$title" --body "$body" ;;
    "Edit body")
      local tmp_body
      tmp_body="$(mktemp /tmp/gitops-pr-body.XXXXXX)"
      printf '%s' "$body" > "$tmp_body"
      edit_in_editor "$tmp_body"
      body="$(cat "$tmp_body")"
      rm -f "$tmp_body"
      [[ -z "$body" ]] && die "Aborted — empty body."
      gh pr create --base "$base_branch" --title "$title" --body "$body" ;;
    *)
      info "PR creation skipped. Body saved to /tmp/gitops_pr_body.md"
      echo "$body" > /tmp/gitops_pr_body.md ;;
  esac
}

cmd_auto() {
  local branch
  branch="$(current_branch)"

  # Step 1: if on a protected branch, create a feature branch first
  if is_main_branch "$branch"; then
    info "On '$branch' — creating a feature branch first"
    cmd_branch
  fi

  # Step 2: stage + commit
  cmd_commit

  # Step 3: push current branch
  local current
  current="$(current_branch)"
  info "Pushing '$current'…"
  git push -u origin "$current" 2>/dev/null || info "Push failed or already pushed — continuing"

  # Step 4: open PR
  if command -v gh &>/dev/null; then
    cmd_pr
  else
    info "gh not found — skipping PR creation (install: https://cli.github.com)"
  fi
}

# ── Entrypoint ────────────────────────────────────────────────────────────────
# Parse flags before the subcommand
ARGS=()
for arg in "$@"; do
  case "$arg" in
    --no-ai) NO_AI=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

[[ "$NO_AI" -eq 0 ]] && require git opencode gum || require git gum

case "${1:-help}" in
  commit) cmd_commit ;;
  branch) cmd_branch ;;
  pr)     cmd_pr ;;
  auto)   cmd_auto ;;
  *)
    echo "Usage: gitops [--no-ai] <command>"
    echo ""
    echo "  commit   Pick files to stage, generate commit message, and commit"
    echo "  branch   Generate and checkout a new branch (feat/fix/chore/…)"
    echo "  pr       Generate PR description and open with gh cli"
    echo "  auto     Full flow: branch (if on main) → commit → push → pr"
    echo ""
    echo "Flags:"
    echo "  --no-ai  Skip AI generation; enter commit message / branch name / PR body manually"
    echo ""
    echo "Env vars:"
    echo "  GITOPS_MODEL    opencode model string (default: github-copilot/gpt-5.4-mini)"
    echo "  GITOPS_VARIANT  reasoning effort variant (default: low; set empty to omit)"
    echo "  GITOPS_BASE     base branch for PRs (default: main)"
    ;;
esac
