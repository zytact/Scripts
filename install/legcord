#!/usr/bin/env bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ -z "$1" ]; then
	echo -e "${RED}Error: GitHub tar file URL is required${NC}"
	echo "Usage: $0 <github-tar-url>"
	echo "Example: $0 https://github.com/Legcord/Legcord/releases/download/v1.2.2/Legcord-1.2.2-linux-amd64.tar.gz"
	exit 1
fi

GITHUB_URL="$1"
ICON_URL="https://avatars.githubusercontent.com/u/85643862?s=200&v=4"
TEMP_DIR=$(mktemp -d)
INSTALL_DIR="/opt/legcord"
DESKTOP_FILE="$HOME/.local/share/applications/legcord.desktop"
ICON_DIR="$HOME/.local/share/icons"

echo -e "${GREEN}Starting Legcord installation...${NC}"

echo -e "${YELLOW}Downloading from: $GITHUB_URL${NC}"
cd "$TEMP_DIR"

FILENAME=$(basename "$GITHUB_URL")
curl -L -o "$FILENAME" "$GITHUB_URL"

if [ $? -ne 0 ]; then
	echo -e "${RED}Failed to download file${NC}"
	rm -rf "$TEMP_DIR"
	exit 1
fi

echo -e "${YELLOW}Extracting archive...${NC}"
tar -xvf "$FILENAME"

EXTRACTED_FOLDER=$(find . -maxdepth 1 -type d ! -name "." | head -n 1)

if [ -z "$EXTRACTED_FOLDER" ]; then
	echo -e "${RED}No folder found after extraction${NC}"
	rm -rf "$TEMP_DIR"
	exit 1
fi

if [ -d "$INSTALL_DIR" ]; then
	echo -e "${YELLOW}Removing existing installation...${NC}"
	sudo rm -rf "$INSTALL_DIR"
fi

echo -e "${YELLOW}Installing to $INSTALL_DIR...${NC}"
sudo mv "$EXTRACTED_FOLDER" "$INSTALL_DIR"

echo -e "${YELLOW}Downloading icon...${NC}"
mkdir -p "$ICON_DIR"
curl -L -o "$ICON_DIR/legcord.png" "$ICON_URL"

mkdir -p "$HOME/.local/share/applications"

echo -e "${YELLOW}Creating desktop entry...${NC}"
cat >"$DESKTOP_FILE" <<EOF
[Desktop Entry]
Name=Legcord
Exec=/opt/legcord/Legcord %U
Terminal=false
Type=Application
Icon=${ICON_DIR}/legcord.png
Categories=Network;InstantMessaging;
StartupNotify=true

EOF

chmod +x "$DESKTOP_FILE"

if command -v update-desktop-database &>/dev/null; then
	update-desktop-database "$HOME/.local/share/applications"
fi

echo -e "${YELLOW}Cleaning up temporary files...${NC}"
rm -rf "$TEMP_DIR"

echo -e "${GREEN}Installation complete!${NC}"
echo -e "${GREEN}Desktop entry created at: $DESKTOP_FILE${NC}"
echo -e "${GREEN}Legcord installed at: $INSTALL_DIR${NC}"
