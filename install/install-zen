#!/usr/bin/env bash

set -e

DRY_RUN=false
FORCE=false
for arg in "$@"; do
    case "$arg" in
        -f|--force)   FORCE=true ;;
        -n|--dry-run) DRY_RUN=true ;;
        *) gum log --level error "Unknown option: $arg"; exit 1 ;;
    esac
done

gum style --bold --foreground 212 "Zen Browser Installer"

choice=$(gum choose --header "Select version to install:" "Stable" "Twilight (nightly)") || exit 1

case "$choice" in
    Stable)
        RELEASE_TAG=""
        INSTALL_DIR="/opt/zen-browser"
        DESKTOP_FILE="/usr/share/applications/zen-browser.desktop"
        APP_NAME="Zen Browser"
        WM_CLASS="zen"
        ;;
    "Twilight (nightly)")
        RELEASE_TAG="twilight-1"
        INSTALL_DIR="/opt/zen-browser-twilight"
        DESKTOP_FILE="/usr/share/applications/zen-browser-twilight.desktop"
        APP_NAME="Zen Browser (Twilight)"
        WM_CLASS="zen-twilight"
        VERSION_FILE=""
        ;;
esac

gum log --level info "Fetching release info for ${RELEASE_TAG:-latest}..."
RELEASE_JSON=$(gh release view --repo zen-browser/desktop ${RELEASE_TAG:+"$RELEASE_TAG"} --json assets,body,tagName)
LATEST_VERSION=$(echo "$RELEASE_JSON" | jq -r '.tagName')
DOWNLOAD_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | test("zen\\.linux-x86_64\\.tar\\.xz")) | .url')

VERSION_FILE="${VERSION_FILE-$INSTALL_DIR/.installed_version}"
if [ -n "$VERSION_FILE" ] && [ -f "$VERSION_FILE" ]; then
    INSTALLED_VERSION=$(cat "$VERSION_FILE")
    if [ "$INSTALLED_VERSION" = "$LATEST_VERSION" ]; then
        if [ "$FORCE" = true ]; then
            gum log --level warn "${APP_NAME} ${LATEST_VERSION} already installed — forcing reinstall."
        else
            gum log --level info "${APP_NAME} is already up to date (${LATEST_VERSION})."
            exit 0
        fi
    else
        gum log --level warn "Installed: ${INSTALLED_VERSION} → Latest: ${LATEST_VERSION}"
    fi
else
    gum log --level info "Latest version: ${LATEST_VERSION}"
fi

CHANGELOG=$(echo "$RELEASE_JSON" | jq -r '.body')
if [[ -n "$CHANGELOG" && "$CHANGELOG" != "null" ]]; then
    echo ""
    printf '%s\n' "$CHANGELOG" | gum format --type markdown | gum pager
else
    gum log --level warn "No release notes available for ${RELEASE_TAG:-latest}."
fi
echo ""

gum confirm "Proceed with installation?" || { echo "Installation cancelled."; exit 0; }

if [ "$DRY_RUN" = true ]; then
    gum log --level info "[dry run] Simulating installation..."
    gum spin --spinner globe  --title "[dry run] Downloading zen.linux-x86_64.tar.xz..." -- sleep 2
    gum spin --spinner jump   --title "[dry run] Extracting archive..."                   -- sleep 1
    gum spin --spinner points --title "[dry run] Installing to $INSTALL_DIR..."           -- sleep 1
    gum log --level warn "[dry run] Would write desktop entry to $DESKTOP_FILE"
    gum spin --spinner pulse  --title "[dry run] Updating desktop database..."            -- sleep 1
    gum log --level info "[dry run] Done! Would have installed ${APP_NAME} ${LATEST_VERSION} to ${INSTALL_DIR}"
    exit 0
fi

if [ -z "$DOWNLOAD_URL" ]; then
    gum log --level error "Failed to find download URL for zen.linux-x86_64.tar.xz"
    exit 1
fi

TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

gum log --level info "Downloading from: $DOWNLOAD_URL"
curl -L -o "$TEMP_DIR/zen.tar.xz" "$DOWNLOAD_URL"

gum spin --spinner jump   --title "Extracting archive..."                           -- tar -xf "$TEMP_DIR/zen.tar.xz" -C "$TEMP_DIR"

EXTRACTED=$(find "$TEMP_DIR" -maxdepth 1 -mindepth 1 -type d | head -n 1)
if [ -z "$EXTRACTED" ]; then
    gum log --level error "No directory found after extraction"
    exit 1
fi

if [ -d "$INSTALL_DIR" ]; then
    gum spin --spinner dot    --title "Removing existing installation at $INSTALL_DIR..." -- sudo rm -rf "$INSTALL_DIR"
fi

gum spin --spinner points --title "Installing to $INSTALL_DIR..."                   -- sudo mv "$EXTRACTED" "$INSTALL_DIR"

gum log --level info "Creating desktop entry..."
sudo tee "$DESKTOP_FILE" > /dev/null <<EOF
[Desktop Entry]
Name=${APP_NAME}
Exec=${INSTALL_DIR}/zen %U
Type=Application
Icon=${INSTALL_DIR}/browser/chrome/icons/default/default128.png
Terminal=false
Categories=Network;WebBrowser;
MimeType=application/pdf;application/rdf+xml;application/rss+xml;application/xhtml+xml;application/xhtml_xml;application/xml;image/gif;image/jpeg;image/png;image/webp;text/html;text/xml;x-scheme-handler/http;x-scheme-handler/https;
Actions=new-window;new-private-window;
StartupWMClass=${WM_CLASS}
EOF

gum spin --spinner pulse  --title "Updating desktop database..."                    -- sudo update-desktop-database /usr/share/applications/

[ -n "$VERSION_FILE" ] && echo "$LATEST_VERSION" | sudo tee "$VERSION_FILE" > /dev/null

gum log --level info "Done! ${APP_NAME} ${LATEST_VERSION} installed to ${INSTALL_DIR}"
