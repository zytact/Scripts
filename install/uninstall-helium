#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}Helium Browser Uninstaller${NC}"
echo "Select version to uninstall:"
echo "  1) Stable"
echo "  2) Pre-release"
echo -n "Choice [1/2]: "
read -r choice

case "$choice" in
    1)
        VARIANT="stable"
        INSTALL_DIR="/opt/helium"
        DESKTOP_FILE="$HOME/.local/share/applications/helium.desktop"
        ;;
    2)
        VARIANT="pre-release"
        INSTALL_DIR="/opt/helium-prerelease"
        DESKTOP_FILE="$HOME/.local/share/applications/helium-prerelease.desktop"
        ;;
    *)
        echo -e "${RED}Invalid choice. Exiting.${NC}"
        exit 1
        ;;
esac

echo -e "${YELLOW}Uninstalling Helium Browser ($VARIANT)...${NC}"

if [ -d "$INSTALL_DIR" ]; then
    sudo rm -rf "$INSTALL_DIR"
    echo -e "${GREEN}Removed installation directory.${NC}"
else
    echo -e "${YELLOW}Installation directory not found (already removed?).${NC}"
fi

if [ -f "$DESKTOP_FILE" ]; then
    rm -f "$DESKTOP_FILE"
    echo -e "${GREEN}Removed desktop entry.${NC}"
else
    echo -e "${YELLOW}Desktop entry not found (already removed?).${NC}"
fi

if command -v update-desktop-database &>/dev/null; then
    update-desktop-database "$HOME/.local/share/applications/"
fi

echo -e "${GREEN}Done! Helium Browser ($VARIANT) uninstalled.${NC}"
