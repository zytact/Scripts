#!/usr/bin/env bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}Helium Browser Installer${NC}"
echo "Select version to install:"
echo "  1) Stable"
echo "  2) Pre-release"
echo -n "Choice [1/2]: "
read -r choice

case "$choice" in
    1)
        RELEASE_TAG=""
        INSTALL_DIR="/opt/helium"
        DESKTOP_FILE="$HOME/.local/share/applications/helium.desktop"
        APP_NAME="Helium Browser"
        ;;
    2)
        RELEASE_TAG="$(gh release list --repo imputnet/helium-linux --limit 10 | awk '/Pre-release/ {print $1; exit}')"
        if [ -z "$RELEASE_TAG" ]; then
            echo -e "${RED}No pre-release found.${NC}"
            exit 1
        fi
        INSTALL_DIR="/opt/helium-prerelease"
        DESKTOP_FILE="$HOME/.local/share/applications/helium-prerelease.desktop"
        APP_NAME="Helium Browser (Pre-release)"
        ;;
    *)
        echo -e "${RED}Invalid choice. Exiting.${NC}"
        exit 1
        ;;
esac

echo -e "${YELLOW}Fetching release info for ${RELEASE_TAG:-latest}...${NC}"
RELEASE_JSON=$(gh release view --repo imputnet/helium-linux ${RELEASE_TAG:+"$RELEASE_TAG"} --json assets,body,tagName)
RELEASE_TAG=$(echo "$RELEASE_JSON" | jq -r '.tagName')
DOWNLOAD_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | test("x86_64_linux\\.tar\\.xz$")) | .url')

VERSION_FILE="$INSTALL_DIR/.installed_version"
if [ -f "$VERSION_FILE" ]; then
    INSTALLED_VERSION=$(cat "$VERSION_FILE")
    if [ "$INSTALLED_VERSION" = "$RELEASE_TAG" ]; then
        echo -e "${GREEN}${APP_NAME} is already up to date (${RELEASE_TAG}).${NC}"
        exit 0
    fi
    echo -e "${YELLOW}Installed: ${INSTALLED_VERSION} → Latest: ${RELEASE_TAG}${NC}"
else
    echo -e "${YELLOW}Latest version: ${RELEASE_TAG}${NC}"
fi

CHANGELOG=$(echo "$RELEASE_JSON" | jq -r '.body')
if [[ -n "$CHANGELOG" && "$CHANGELOG" != "null" ]]; then
    echo ""
    echo "=== Release Notes: ${RELEASE_TAG} ==="
    echo "$CHANGELOG"
    echo "=================================="
else
    echo -e "${YELLOW}(No release notes available for ${RELEASE_TAG})${NC}"
fi
echo ""

read -r -p "Proceed with installation? [y/N] " confirm
case "$confirm" in
    y|Y|yes|YES) ;;
    *) echo "Installation cancelled."; exit 0 ;;
esac

if [ -z "$DOWNLOAD_URL" ]; then
    echo -e "${RED}Failed to find download URL for x86_64_linux.tar.xz${NC}"
    exit 1
fi

TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

echo -e "${YELLOW}Downloading from: $DOWNLOAD_URL${NC}"
curl -L -o "$TEMP_DIR/helium.tar.xz" "$DOWNLOAD_URL"

echo -e "${YELLOW}Extracting archive...${NC}"
tar -xf "$TEMP_DIR/helium.tar.xz" -C "$TEMP_DIR"

EXTRACTED=$(find "$TEMP_DIR" -maxdepth 1 -mindepth 1 -type d | head -n 1)
if [ -z "$EXTRACTED" ]; then
    echo -e "${RED}No directory found after extraction${NC}"
    exit 1
fi

if [ -d "$INSTALL_DIR" ]; then
    echo -e "${YELLOW}Removing existing installation at $INSTALL_DIR...${NC}"
    sudo rm -rf "$INSTALL_DIR"
fi

echo -e "${YELLOW}Installing to $INSTALL_DIR...${NC}"
sudo mv "$EXTRACTED" "$INSTALL_DIR"

mkdir -p "$(dirname "$DESKTOP_FILE")"

echo -e "${YELLOW}Creating desktop entry...${NC}"
cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Name=${APP_NAME}
Exec=${INSTALL_DIR}/helium %U
Type=Application
Icon=${INSTALL_DIR}/product_logo_256.png
Terminal=false
Categories=Network;WebBrowser;
MimeType=application/pdf;application/rdf+xml;application/rss+xml;application/xhtml+xml;application/xhtml_xml;application/xml;image/gif;image/jpeg;image/png;image/webp;text/html;text/xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=true
EOF

chmod +x "$DESKTOP_FILE"

if command -v update-desktop-database &>/dev/null; then
    update-desktop-database "$(dirname "$DESKTOP_FILE")"
fi

echo "$RELEASE_TAG" | sudo tee "$INSTALL_DIR/.installed_version" > /dev/null

echo -e "${GREEN}Done! ${APP_NAME} ${RELEASE_TAG} installed to ${INSTALL_DIR}${NC}"
