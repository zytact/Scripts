#!/usr/bin/env bash

set -e

DRY_RUN=false
FORCE=false
for arg in "$@"; do
    case "$arg" in
        -f|--force)   FORCE=true ;;
        -n|--dry-run) DRY_RUN=true ;;
        *) gum log --level error "Unknown option: $arg"; exit 1 ;;
    esac
done

gum style --bold --foreground 212 "Helium Browser Installer"

choice=$(gum choose --header "Select version to install:" "Stable" "Pre-release") || exit 1

case "$choice" in
    Stable)
        RELEASE_TAG=""
        INSTALL_DIR="/opt/helium"
        DESKTOP_FILE="$HOME/.local/share/applications/helium.desktop"
        APP_NAME="Helium Browser"
        ;;
    Pre-release)
        RELEASE_TAG="$(gh release list --repo imputnet/helium-linux --limit 10 | awk '/Pre-release/ {print $1; exit}')"
        if [ -z "$RELEASE_TAG" ]; then
            gum log --level error "No pre-release found."
            exit 1
        fi
        INSTALL_DIR="/opt/helium-prerelease"
        DESKTOP_FILE="$HOME/.local/share/applications/helium-prerelease.desktop"
        APP_NAME="Helium Browser (Pre-release)"
        ;;
esac

gum log --level info "Fetching release info for ${RELEASE_TAG:-latest}..."
RELEASE_JSON=$(gh release view --repo imputnet/helium-linux ${RELEASE_TAG:+"$RELEASE_TAG"} --json assets,body,tagName)
RELEASE_TAG=$(echo "$RELEASE_JSON" | jq -r '.tagName')
DOWNLOAD_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | test("x86_64_linux\\.tar\\.xz$")) | .url')

VERSION_FILE="$INSTALL_DIR/.installed_version"
if [ -f "$VERSION_FILE" ]; then
    INSTALLED_VERSION=$(cat "$VERSION_FILE")
    if [ "$INSTALLED_VERSION" = "$RELEASE_TAG" ]; then
        if [ "$FORCE" = true ]; then
            gum log --level warn "${APP_NAME} ${RELEASE_TAG} already installed — forcing reinstall."
        else
            gum log --level info "${APP_NAME} is already up to date (${RELEASE_TAG})."
            exit 0
        fi
    else
        gum log --level warn "Installed: ${INSTALLED_VERSION} → Latest: ${RELEASE_TAG}"
    fi
else
    gum log --level info "Latest version: ${RELEASE_TAG}"
fi

CHANGELOG=$(echo "$RELEASE_JSON" | jq -r '.body')
if [[ -n "$CHANGELOG" && "$CHANGELOG" != "null" ]]; then
    echo ""
    printf '%s\n' "$CHANGELOG" | gum format --type markdown | gum pager
else
    gum log --level warn "No release notes available for ${RELEASE_TAG}."
fi
echo ""

gum confirm "Proceed with installation?" || { echo "Installation cancelled."; exit 0; }

if [ "$DRY_RUN" = true ]; then
    gum log --level info "[dry run] Simulating installation..."
    gum spin --spinner globe  --title "[dry run] Downloading x86_64_linux.tar.xz..."  -- sleep 2
    gum spin --spinner jump   --title "[dry run] Extracting archive..."                -- sleep 1
    gum spin --spinner points --title "[dry run] Installing to $INSTALL_DIR..."        -- sleep 1
    gum log --level warn "[dry run] Would write desktop entry to $DESKTOP_FILE"
    gum spin --spinner pulse  --title "[dry run] Updating desktop database..."         -- sleep 1
    gum log --level info "[dry run] Done! Would have installed ${APP_NAME} ${RELEASE_TAG} to ${INSTALL_DIR}"
    exit 0
fi

if [ -z "$DOWNLOAD_URL" ]; then
    gum log --level error "Failed to find download URL for x86_64_linux.tar.xz"
    exit 1
fi

TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

gum log --level info "Downloading from: $DOWNLOAD_URL"
curl -L -o "$TEMP_DIR/helium.tar.xz" "$DOWNLOAD_URL"

gum spin --spinner jump   --title "Extracting archive..."                           -- tar -xf "$TEMP_DIR/helium.tar.xz" -C "$TEMP_DIR"

EXTRACTED=$(find "$TEMP_DIR" -maxdepth 1 -mindepth 1 -type d | head -n 1)
if [ -z "$EXTRACTED" ]; then
    gum log --level error "No directory found after extraction"
    exit 1
fi

if [ -d "$INSTALL_DIR" ]; then
    gum spin --spinner dot    --title "Removing existing installation at $INSTALL_DIR..." -- sudo rm -rf "$INSTALL_DIR"
fi

gum spin --spinner points --title "Installing to $INSTALL_DIR..."                   -- sudo mv "$EXTRACTED" "$INSTALL_DIR"

mkdir -p "$(dirname "$DESKTOP_FILE")"

gum log --level info "Creating desktop entry..."
cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Name=${APP_NAME}
Exec=${INSTALL_DIR}/helium %U
Type=Application
Icon=${INSTALL_DIR}/product_logo_256.png
Terminal=false
Categories=Network;WebBrowser;
MimeType=application/pdf;application/rdf+xml;application/rss+xml;application/xhtml+xml;application/xhtml_xml;application/xml;image/gif;image/jpeg;image/png;image/webp;text/html;text/xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=true
EOF

chmod +x "$DESKTOP_FILE"

if command -v update-desktop-database &>/dev/null; then
    gum spin --spinner pulse  --title "Updating desktop database..."                -- update-desktop-database "$(dirname "$DESKTOP_FILE")"
fi

echo "$RELEASE_TAG" | sudo tee "$INSTALL_DIR/.installed_version" > /dev/null

gum log --level info "Done! ${APP_NAME} ${RELEASE_TAG} installed to ${INSTALL_DIR}"
