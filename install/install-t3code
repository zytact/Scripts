#!/usr/bin/env bash
set -euo pipefail

REPO="pingdotgg/t3code"
APPIMAGE_DIR="$HOME/.local/bin/appimages"
APP_DIR="$APPIMAGE_DIR/t3code"
DESKTOP_ENTRY="$HOME/.local/share/applications/t3code.desktop"
DESKTOP_DB="$HOME/.local/share/applications"
ICON_SOURCE="$HOME/.local/share/icons/t3code.png"
ICON_URL="https://github.com/pingdotgg/t3code/raw/main/assets/prod/black-universal-1024.png"

detect_distro() {
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release
        case "$ID" in
            debian|ubuntu|linuxmint|pop)
                echo "debian"
                ;;
            fedora|rhel|centos|almalinux|rocky)
                echo "fedora"
                ;;
            *)
                echo "unknown"
                ;;
        esac
    else
        echo "unknown"
    fi
}

ensure_gh() {
    if command -v gh >/dev/null 2>&1; then
        return 0
    fi

    echo "GitHub CLI (gh) is required to install T3 Code."
    read -r -p "Install gh now? [y/N] " answer

    case "$answer" in
        y|Y|yes|YES)
            local distro
            distro=$(detect_distro)

            case "$distro" in
                debian)
                    (type -p wget >/dev/null || (sudo apt update && sudo apt install wget -y)) \
                    && (type -p curl >/dev/null || sudo apt install curl -y) \
                    && sudo mkdir -p -m 755 /etc/apt/keyrings \
                    && out=$(mktemp) && wget -nv -O$out https://cli.github.com/packages/githubcli-archive-keyring.gpg \
                    && cat $out | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
                    && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
                    && sudo mkdir -p -m 755 /etc/apt/sources.list.d \
                    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
                    && sudo apt update \
                    && sudo apt install gh -y
                    ;;
                fedora)
                    (type -p wget >/dev/null || sudo dnf install wget -y) \
                    && (type -p curl >/dev/null || sudo dnf install curl -y) \
                    && sudo dnf install dnf5-plugins \
                    && sudo dnf config-manager addrepo --from-repofile=https://cli.github.com/packages/rpm/gh-cli.repo \
                    && sudo dnf install gh --repo gh-cli
                    ;;
                *)
                    echo "Error: Unsupported distribution. gh installation is supported on Debian/Ubuntu and Fedora/RHEL-based systems."
                    exit 1
                    ;;
            esac
            ;;
        *)
            echo "Skipping install because this script needs gh to fetch T3 Code releases."
            exit 1
            ;;
    esac
}

ensure_gh_login() {
    if gh auth status >/dev/null 2>&1; then
        return 0
    fi

    echo "Signing in to GitHub CLI..."
    gh auth login
}

get_latest_stable() {
    gh api repos/$REPO/releases | jq -r '.[] | select(.prerelease == false) | .tag_name' | head -1
}

get_stable_versions() {
    gh api repos/$REPO/releases | jq -r '.[] | select(.prerelease == false) | .tag_name'
}

select_stable_version() {
    local versions=()
    local selected

    mapfile -t versions < <(get_stable_versions)

    if [[ ${#versions[@]} -eq 0 ]]; then
        echo "Error: Could not find any stable releases." >&2
        return 1
    fi

    echo "Select a stable version:" >&2
    PS3="Enter choice number: "
    select selected in "${versions[@]}"; do
        if [[ -n "${selected:-}" ]]; then
            echo "$selected"
            return 0
        fi
        echo "Invalid selection. Try again." >&2
    done
}

download_appimage() {
    local version="$1"
    local appimage_url="https://github.com/$REPO/releases/download/${version}/T3-Code-${version#v}-x86_64.AppImage"

    echo "Downloading T3 Code ${version}..."
    curl -L --progress-bar -o "/tmp/T3-Code-${version#v}-x86_64.AppImage" "$appimage_url"

    echo "Making executable..."
    chmod +x "/tmp/T3-Code-${version#v}-x86_64.AppImage"

    echo "Moving to $APP_DIR..."
    mkdir -p "$APP_DIR"
    rm -f "$APP_DIR/t3code.AppImage"
    mv "/tmp/T3-Code-${version#v}-x86_64.AppImage" "$APP_DIR/t3code.AppImage"
}

download_icon() {
    local out_icon="$1"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$ICON_URL" -o "$out_icon"
        return 0
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -qO "$out_icon" "$ICON_URL"
        return 0
    fi

    echo "Error: curl or wget is required to download the desktop icon"
    return 1
}

extract_and_integrate() {
    mkdir -p "$HOME/.local/share/icons"
    download_icon "$ICON_SOURCE"

    echo "Creating desktop entry..."
    mkdir -p "$DESKTOP_DB"
    cat > "$DESKTOP_ENTRY" <<EOF
[Desktop Entry]
Type=Application
Name=T3 Code
Comment=AI-powered code editor
Exec=$APP_DIR/t3code.AppImage --ozone-platform=x11 %F
Icon=$ICON_SOURCE
Terminal=false
StartupNotify=true
StartupWMClass=t3 code (alpha)
Categories=Development;IDE;TextEditor;
MimeType=text/plain;text/x-chdr;text/x-csrc;text/x-cxxsrc;text/x-java;text/x-python;text/x-script;
EOF

    echo "Refreshing desktop database..."
    update-desktop-database "$HOME/.local/share/applications/" 2>/dev/null || true

    echo ""
    echo "Done! T3 Code (stable) installed."
    echo "You can now find it in your app launcher."
}

install_from_appimage() {
    local appimage_path="$1"

    echo "Using local AppImage: $appimage_path"

    if [[ ! -f "$appimage_path" ]]; then
        echo "Error: File not found: $appimage_path"
        exit 1
    fi

    echo "Making executable..."
    chmod +x "$appimage_path"

    echo "Copying to $APP_DIR..."
    mkdir -p "$APP_DIR"
    rm -f "$APP_DIR/t3code.AppImage"
    cp "$appimage_path" "$APP_DIR/t3code.AppImage"

    extract_and_integrate
}

get_version_from_arg() {
    local arg="$1"

    if [[ "$arg" == *.AppImage && -f "$arg" ]]; then
        echo "local"
    elif [[ "$arg" =~ ^v[0-9] ]]; then
        echo "version"
    else
        echo "version"
    fi
}

usage() {
    echo "Usage: $0 [--select|-s] [version|path-to-AppImage]"
    echo ""
    echo "Examples:"
    echo "  $0                    # install latest stable"
    echo "  $0 --select           # interactively choose stable version"
    echo "  $0 0.0.19             # install stable v0.0.19"
    echo "  $0 ./T3-Code.AppImage # install from local AppImage"
}

main() {
    local arg=""
    local select_mode="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s|--select)
                select_mode="true"
                ;;
            -h|--help)
                usage
                return 0
                ;;
            *)
                if [[ -z "$arg" ]]; then
                    arg="$1"
                else
                    echo "Error: Unexpected argument: $1"
                    usage
                    return 1
                fi
                ;;
        esac
        shift
    done

    echo "Installing T3 Code (stable)..."
    echo ""

    if [[ -n "$arg" && "${arg%.AppImage}" != "$arg" && -f "$arg" ]]; then
        install_from_appimage "$arg"
        return
    fi

    ensure_gh
    ensure_gh_login

    if [[ "$select_mode" == "true" ]]; then
        local version
        version=$(select_stable_version)
        echo "Installing selected version: $version"
        download_appimage "$version"
    elif [[ -n "$arg" ]]; then
        local version="$arg"
        if [[ ! "$version" =~ ^v ]]; then
            version="v$version"
        fi
        echo "Installing version: $version"
        download_appimage "$version"
    else
        local version
        version=$(get_latest_stable)
        echo "Latest stable version: $version"
        download_appimage "$version"
    fi

    extract_and_integrate
}

main "$@"
