#!/usr/bin/env bash
set -euo pipefail

REPO="pingdotgg/t3code"
APPIMAGE_DIR="$HOME/.local/bin/appimages"
DESKTOP_DB="$HOME/.local/share/applications"
ICON_SOURCE="$HOME/.local/share/icons/t3code.png"
ICON_URL="https://github.com/pingdotgg/t3code/raw/main/assets/prod/black-universal-1024.png"

echo "Select version to install:"
echo "  1) Stable"
echo "  2) Nightly"
echo -n "Choice [1/2]: "
read -r choice

case "$choice" in
    1)
        VARIANT="stable"
        APP_DIR="$APPIMAGE_DIR/t3code"
        DESKTOP_ENTRY="$HOME/.local/share/applications/t3code.desktop"
        APPIMAGE_NAME="t3code.AppImage"
        DESKTOP_APP_NAME="T3 Code"
        STARTUP_WM_CLASS="t3 code (alpha)"
        PRERELEASE="false"
        ;;
    2)
        VARIANT="nightly"
        APP_DIR="$APPIMAGE_DIR/t3code-nightly"
        DESKTOP_ENTRY="$HOME/.local/share/applications/t3code-nightly.desktop"
        APPIMAGE_NAME="t3code-nightly.AppImage"
        DESKTOP_APP_NAME="T3 Code (Nightly)"
        STARTUP_WM_CLASS="t3 code (nightly)"
        PRERELEASE="true"
        ;;
    *)
        echo "Invalid choice. Exiting."
        exit 1
        ;;
esac

detect_distro() {
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release
        case "$ID" in
            debian|ubuntu|linuxmint|pop)
                echo "debian"
                ;;
            fedora|rhel|centos|almalinux|rocky)
                echo "fedora"
                ;;
            *)
                echo "unknown"
                ;;
        esac
    else
        echo "unknown"
    fi
}

ensure_gh() {
    if command -v gh >/dev/null 2>&1; then
        return 0
    fi

    echo "GitHub CLI (gh) is required to install T3 Code."
    read -r -p "Install gh now? [y/N] " answer

    case "$answer" in
        y|Y|yes|YES)
            local distro
            distro=$(detect_distro)

            case "$distro" in
                debian)
                    (type -p wget >/dev/null || (sudo apt update && sudo apt install wget -y)) \
                    && (type -p curl >/dev/null || sudo apt install curl -y) \
                    && sudo mkdir -p -m 755 /etc/apt/keyrings \
                    && out=$(mktemp) && wget -nv -O$out https://cli.github.com/packages/githubcli-archive-keyring.gpg \
                    && cat $out | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
                    && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
                    && sudo mkdir -p -m 755 /etc/apt/sources.list.d \
                    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
                    && sudo apt update \
                    && sudo apt install gh -y
                    ;;
                fedora)
                    (type -p wget >/dev/null || sudo dnf install wget -y) \
                    && (type -p curl >/dev/null || sudo dnf install curl -y) \
                    && sudo dnf install dnf5-plugins \
                    && sudo dnf config-manager addrepo --from-repofile=https://cli.github.com/packages/rpm/gh-cli.repo \
                    && sudo dnf install gh --repo gh-cli
                    ;;
                *)
                    echo "Error: Unsupported distribution. gh installation is supported on Debian/Ubuntu and Fedora/RHEL-based systems."
                    exit 1
                    ;;
            esac
            ;;
        *)
            echo "Skipping install because this script needs gh to fetch T3 Code releases."
            exit 1
            ;;
    esac
}

ensure_gh_login() {
    if gh auth status >/dev/null 2>&1; then
        return 0
    fi

    echo "Signing in to GitHub CLI..."
    gh auth login
}

get_installed_version() {
    local version_file="$APP_DIR/.version"
    if [[ -f "$version_file" ]]; then
        cat "$version_file"
    fi
}

save_installed_version() {
    local version="$1"
    mkdir -p "$APP_DIR"
    echo "$version" > "$APP_DIR/.version"
}

get_latest_version() {
    gh api repos/$REPO/releases | jq -r ".[] | select(.prerelease == $PRERELEASE) | .tag_name" | head -1
}

get_versions() {
    gh api repos/$REPO/releases | jq -r ".[] | select(.prerelease == $PRERELEASE) | .tag_name"
}

select_version() {
    local versions=()
    local selected

    mapfile -t versions < <(get_versions)

    if [[ ${#versions[@]} -eq 0 ]]; then
        echo "Error: Could not find any $VARIANT releases." >&2
        return 1
    fi

    echo "Select a $VARIANT version:" >&2
    PS3="Enter choice number: "
    select selected in "${versions[@]}"; do
        if [[ -n "${selected:-}" ]]; then
            echo "$selected"
            return 0
        fi
        echo "Invalid selection. Try again." >&2
    done
}

show_changelog() {
    local version="$1"
    echo "Fetching release notes for ${version}..."
    local body
    body=$(gh api repos/$REPO/releases/tags/$version --jq '.body' 2>/dev/null || true)
    if [[ -n "$body" ]]; then
        echo ""
        echo "=== Release Notes: ${version} ==="
        echo "$body"
        echo "=================================="
    else
        echo "(No release notes available for ${version})"
    fi
    echo ""
}

confirm_install() {
    read -r -p "Proceed with installation? [y/N] " answer
    case "$answer" in
        y|Y|yes|YES) return 0 ;;
        *) echo "Installation cancelled."; exit 0 ;;
    esac
}

download_appimage() {
    local version="$1"
    local version_num="$version"

    if [[ "$VARIANT" == "nightly" ]]; then
        version_num="${version#nightly-}"
        version_num="${version_num#v}"
    else
        version_num="${version#v}"
    fi

    local appimage_url="https://github.com/$REPO/releases/download/${version}/T3-Code-${version_num}-x86_64.AppImage"

    echo "Downloading T3 Code ${version}..."
    curl -L --progress-bar -o "/tmp/T3-Code-${version_num}-x86_64.AppImage" "$appimage_url"

    gum spin --spinner dot --title "Setting permissions..." -- chmod +x "/tmp/T3-Code-${version_num}-x86_64.AppImage"

    echo "Moving to $APP_DIR..."
    mkdir -p "$APP_DIR"
    rm -f "$APP_DIR/$APPIMAGE_NAME"
    gum spin --spinner dot --title "Installing AppImage to $APP_DIR..." -- mv "/tmp/T3-Code-${version_num}-x86_64.AppImage" "$APP_DIR/$APPIMAGE_NAME"
}

download_icon() {
    local out_icon="$1"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$ICON_URL" -o "$out_icon"
        return 0
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -qO "$out_icon" "$ICON_URL"
        return 0
    fi

    echo "Error: curl or wget is required to download the desktop icon"
    return 1
}

extract_and_integrate() {
    local version="$1"

    mkdir -p "$HOME/.local/share/icons"
    download_icon "$ICON_SOURCE"

    echo "Creating desktop entry..."
    mkdir -p "$DESKTOP_DB"
    cat > "$DESKTOP_ENTRY" <<EOF
[Desktop Entry]
Type=Application
Name=$DESKTOP_APP_NAME
Comment=AI-powered code editor
Exec=$APP_DIR/$APPIMAGE_NAME --ozone-platform=x11 %F
Icon=$ICON_SOURCE
Terminal=false
StartupNotify=true
StartupWMClass=$STARTUP_WM_CLASS
Categories=Development;IDE;TextEditor;
MimeType=text/plain;text/x-chdr;text/x-csrc;text/x-cxxsrc;text/x-java;text/x-python;text/x-script;
EOF

    gum spin --spinner dot --title "Refreshing desktop database..." -- bash -c 'update-desktop-database "$HOME/.local/share/applications/" 2>/dev/null || true'

    if [[ -n "$version" ]]; then
        save_installed_version "$version"
    fi

    echo ""
    echo "Done! T3 Code ($VARIANT) installed."
    echo "You can now find it in your app launcher."
}

install_from_appimage() {
    local appimage_path="$1"

    echo "Using local AppImage: $appimage_path"

    if [[ ! -f "$appimage_path" ]]; then
        echo "Error: File not found: $appimage_path"
        exit 1
    fi

    gum spin --spinner dot --title "Setting permissions..." -- chmod +x "$appimage_path"

    echo "Copying to $APP_DIR..."
    mkdir -p "$APP_DIR"
    rm -f "$APP_DIR/$APPIMAGE_NAME"
    gum spin --spinner dot --title "Copying to $APP_DIR..." -- cp "$appimage_path" "$APP_DIR/$APPIMAGE_NAME"

    extract_and_integrate ""
}

usage() {
    echo "Usage: $0 [--select|-s] [-f|--force] [version|path-to-AppImage]"
    echo ""
    echo "Examples:"
    echo "  $0                    # install latest"
    echo "  $0 --select           # interactively choose version"
    echo "  $0 0.0.19             # install specific version (stable only)"
    echo "  $0 ./T3-Code.AppImage # install from local AppImage (stable only)"
    echo "  $0 -f / --force       # reinstall even if already up to date"
    echo "  $0 -n / --dry-run     # simulate install UI without writing anything"
}

main() {
    local arg=""
    local select_mode="false"
    local FORCE="false"
    local DRY_RUN="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s|--select)
                select_mode="true"
                ;;
            -f|--force)
                FORCE="true"
                ;;
            -n|--dry-run)
                DRY_RUN="true"
                ;;
            -h|--help)
                usage
                return 0
                ;;
            *)
                if [[ -z "$arg" ]]; then
                    arg="$1"
                else
                    echo "Error: Unexpected argument: $1"
                    usage
                    return 1
                fi
                ;;
        esac
        shift
    done

    echo "Installing T3 Code ($VARIANT)..."
    echo ""

    if [[ "$VARIANT" == "stable" && -n "$arg" && "${arg%.AppImage}" != "$arg" && -f "$arg" ]]; then
        install_from_appimage "$arg"
        return
    fi

    ensure_gh
    ensure_gh_login

    local version
    if [[ "$select_mode" == "true" ]]; then
        version=$(select_version)
        echo "Installing selected version: $version"
    elif [[ -n "$arg" ]]; then
        version="$arg"
        if [[ "$VARIANT" == "stable" && ! "$version" =~ ^v ]]; then
            version="v$version"
        elif [[ "$VARIANT" == "nightly" && ! "$version" =~ ^nightly- ]]; then
            version="nightly-$version"
        fi
        echo "Installing version: $version"
    else
        version=$(get_latest_version)
        echo "Latest $VARIANT version: $version"
    fi

    if [[ -z "$version" ]]; then
        echo "Error: Could not find a $VARIANT release."
        exit 1
    fi

    if [[ "$select_mode" != "true" && -z "$arg" ]]; then
        local installed_version
        installed_version=$(get_installed_version)
        if [[ -n "$installed_version" && "$installed_version" == "$version" ]]; then
            if [[ "$FORCE" == "true" ]]; then
                echo "T3 Code ($VARIANT) ${version} already installed — forcing reinstall."
            else
                echo "T3 Code ($VARIANT) is already up to date ($version). Nothing to do."
                exit 0
            fi
        fi
    fi

    show_changelog "$version"
    confirm_install

    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry run] Simulating installation..."
        gum spin --spinner dot --title "[dry run] Downloading T3 Code ${version}..." -- sleep 2
        gum spin --spinner dot --title "[dry run] Setting permissions..." -- sleep 1
        gum spin --spinner dot --title "[dry run] Installing AppImage to $APP_DIR..." -- sleep 1
        echo "[dry run] Would write desktop entry to $DESKTOP_ENTRY"
        gum spin --spinner dot --title "[dry run] Refreshing desktop database..." -- sleep 1
        echo "[dry run] Done! Would have installed T3 Code ($VARIANT) ${version}."
        return 0
    fi

    download_appimage "$version"
    extract_and_integrate "$version"
}

main "$@"
