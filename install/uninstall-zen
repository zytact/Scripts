#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}Zen Browser Uninstaller${NC}"
echo "Select version to uninstall:"
echo "  1) Stable"
echo "  2) Twilight (nightly)"
echo -n "Choice [1/2]: "
read -r choice

case "$choice" in
    1)
        VARIANT="stable"
        INSTALL_DIR="/opt/zen-browser"
        DESKTOP_FILE="/usr/share/applications/zen-browser.desktop"
        ;;
    2)
        VARIANT="twilight"
        INSTALL_DIR="/opt/zen-browser-twilight"
        DESKTOP_FILE="/usr/share/applications/zen-browser-twilight.desktop"
        ;;
    *)
        echo -e "${RED}Invalid choice. Exiting.${NC}"
        exit 1
        ;;
esac

echo -e "${YELLOW}Uninstalling Zen Browser ($VARIANT)...${NC}"

if [ -d "$INSTALL_DIR" ]; then
    sudo rm -rf "$INSTALL_DIR"
    echo -e "${GREEN}Removed installation directory.${NC}"
else
    echo -e "${YELLOW}Installation directory not found (already removed?).${NC}"
fi

if [ -f "$DESKTOP_FILE" ]; then
    sudo rm -f "$DESKTOP_FILE"
    echo -e "${GREEN}Removed desktop entry.${NC}"
else
    echo -e "${YELLOW}Desktop entry not found (already removed?).${NC}"
fi

sudo update-desktop-database /usr/share/applications/

echo -e "${GREEN}Done! Zen Browser ($VARIANT) uninstalled.${NC}"
