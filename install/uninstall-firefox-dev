#!/usr/bin/env bash

set -e

INSTALL_DIR="/opt/firefox-dev"
DESKTOP_FILE="$HOME/.local/share/applications/firefox-dev.desktop"
APP_NAME="Firefox Developer Edition"

gum style --bold --foreground 212 "Firefox Developer Edition Uninstaller"

if [ ! -d "$INSTALL_DIR" ] && [ ! -f "$DESKTOP_FILE" ]; then
    gum log --level info "${APP_NAME} does not appear to be installed."
    exit 0
fi

[ -d "$INSTALL_DIR" ]   && gum log --level warn "Will remove: $INSTALL_DIR"
[ -f "$DESKTOP_FILE" ]  && gum log --level warn "Will remove: $DESKTOP_FILE"
echo ""

gum confirm "Proceed with uninstallation?" || { echo "Uninstallation cancelled."; exit 0; }

if [ -d "$INSTALL_DIR" ]; then
    gum spin --spinner dot --title "Removing $INSTALL_DIR..." -- sudo rm -rf "$INSTALL_DIR"
    gum log --level info "Removed installation directory."
fi

if [ -f "$DESKTOP_FILE" ]; then
    rm -f "$DESKTOP_FILE"
    gum log --level info "Removed desktop entry."
fi

if command -v update-desktop-database &>/dev/null; then
    gum spin --spinner pulse --title "Updating desktop database..." -- update-desktop-database "$(dirname "$DESKTOP_FILE")"
fi

gum log --level info "Done! ${APP_NAME} uninstalled."
