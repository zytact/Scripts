#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
USAGE_SCRIPT="$SCRIPT_DIR/codex-usage"
SELF_SCRIPT="$SCRIPT_DIR/codex-lock-window-macos"

MESSAGE="${MESSAGE:-Hi}"
OFFSET_SECONDS="${OFFSET_SECONDS:-120}"
BOOTSTRAP_LABEL="${BOOTSTRAP_LABEL:-com.arnab.codex-lock-window.bootstrap}"
FIRE_LABEL="${FIRE_LABEL:-com.arnab.codex-lock-window.fire}"
LAUNCH_AGENTS_DIR="${LAUNCH_AGENTS_DIR:-$HOME/Library/LaunchAgents}"
STATE_DIR="${STATE_DIR:-$HOME/.local/state/codex-lock-window-macos}"
LOG_DIR="${LOG_DIR:-$STATE_DIR/logs}"
BOOTSTRAP_PLIST="${BOOTSTRAP_PLIST:-$LAUNCH_AGENTS_DIR/${BOOTSTRAP_LABEL}.plist}"
FIRE_PLIST="${FIRE_PLIST:-$LAUNCH_AGENTS_DIR/${FIRE_LABEL}.plist}"

usage() {
  cat <<'EOF'
Usage: codex-lock-window-macos [install|schedule|run]

Commands:
  install   Install the login LaunchAgent and schedule the next fire
  schedule  Compute reset + 2 minutes and rewrite the next fire LaunchAgent
  run       Send "Hi" to Codex, then schedule the next fire
EOF
}

require_command() {
  local cmd="$1"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required command: $cmd" >&2
    exit 1
  fi
}

write_plist() {
  local path="$1"
  local label="$2"
  local run_at_load="$3"
  local hour="$4"
  local minute="$5"
  local second="$6"
  local stdout_path="$7"
  local stderr_path="$8"
  shift 8
  local program_args=("$@")

  python3 - "$path" "$label" "$run_at_load" "$hour" "$minute" "$second" "$stdout_path" "$stderr_path" "${program_args[@]}" <<'PY'
import plistlib
import sys

path = sys.argv[1]
label = sys.argv[2]
run_at_load = sys.argv[3] == "true"
hour = int(sys.argv[4])
minute = int(sys.argv[5])
second = int(sys.argv[6])
stdout_path = sys.argv[7]
stderr_path = sys.argv[8]
program_args = sys.argv[9:]

payload = {
    "Label": label,
    "ProgramArguments": program_args,
    "StandardOutPath": stdout_path,
    "StandardErrorPath": stderr_path,
}

if run_at_load:
    payload["RunAtLoad"] = True
else:
    payload["StartCalendarInterval"] = {
        "Hour": hour,
        "Minute": minute,
        "Second": second,
    }

with open(path, "wb") as fh:
    plistlib.dump(payload, fh, sort_keys=False)
PY
}

install_bootstrap_agent() {
  mkdir -p "$LAUNCH_AGENTS_DIR" "$LOG_DIR"

  write_plist \
    "$BOOTSTRAP_PLIST" \
    "$BOOTSTRAP_LABEL" \
    true \
    0 \
    0 \
    0 \
    "$LOG_DIR/bootstrap.stdout.log" \
    "$LOG_DIR/bootstrap.stderr.log" \
    /bin/bash \
    "$SELF_SCRIPT" \
    schedule

  launchctl bootout "gui/$(id -u)" "$BOOTSTRAP_PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$BOOTSTRAP_PLIST"
  launchctl kickstart -k "gui/$(id -u)/$BOOTSTRAP_LABEL"
}

schedule_next_fire() {
  mkdir -p "$LAUNCH_AGENTS_DIR" "$LOG_DIR" "$STATE_DIR"

  local usage_json
  usage_json="$("$USAGE_SCRIPT" --json)"

  local primary_reset_at_epoch
  primary_reset_at_epoch="$(jq -r '.rate_limit.primary_window.reset_at_epoch // empty' <<<"$usage_json")"

  if [[ -z "$primary_reset_at_epoch" ]]; then
    echo "Could not determine 5h window reset time." >&2
    exit 1
  fi

  local schedule_epoch
  schedule_epoch=$(( primary_reset_at_epoch + OFFSET_SECONDS ))

  local fire_hms
  fire_hms="$(python3 - "$schedule_epoch" <<'PY'
from datetime import datetime
import sys

epoch = int(sys.argv[1])
dt = datetime.fromtimestamp(epoch)
print(dt.strftime("%H %M %S %Y-%m-%d %H:%M:%S"))
PY
)"

  local hour minute second formatted_time
  read -r hour minute second _ <<<"$fire_hms"
  formatted_time="$(python3 - "$schedule_epoch" <<'PY'
from datetime import datetime
import sys

epoch = int(sys.argv[1])
print(datetime.fromtimestamp(epoch).strftime("%Y-%m-%d %H:%M:%S"))
PY
)"

  write_plist \
    "$FIRE_PLIST" \
    "$FIRE_LABEL" \
    false \
    "$hour" \
    "$minute" \
    "$second" \
    "$LOG_DIR/fire.stdout.log" \
    "$LOG_DIR/fire.stderr.log" \
    /bin/bash \
    "$SELF_SCRIPT" \
    run

  launchctl bootout "gui/$(id -u)" "$FIRE_PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$FIRE_PLIST"

  printf '%s\n' "$schedule_epoch" > "$STATE_DIR/next-fire-epoch"
  printf '%s\n' "$formatted_time" > "$STATE_DIR/next-fire-localtime"

  echo "Scheduled macOS Codex auto-lock at $formatted_time"
  echo "Bootstrap plist: $BOOTSTRAP_PLIST"
  echo "Fire plist: $FIRE_PLIST"
}

run_and_reschedule() {
  mkdir -p "$LOG_DIR"

  {
    printf '[%s] Sending auto-lock message: %s\n' "$(date '+%F %T')" "$MESSAGE"
    codex exec --skip-git-repo-check --cd "$HOME" --ephemeral "$MESSAGE"
    sleep 10
    printf '[%s] Rescheduling next macOS auto-lock\n' "$(date '+%F %T')"
  } >> "$LOG_DIR/run.log" 2>&1

  "$SELF_SCRIPT" schedule >> "$LOG_DIR/run.log" 2>&1
}

main() {
  local command="${1:-install}"

  case "$command" in
    install|schedule|run)
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown command: $command" >&2
      usage >&2
      exit 1
      ;;
  esac

  if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "codex-lock-window-macos must be run on macOS." >&2
    exit 1
  fi

  require_command python3
  require_command jq
  require_command launchctl
  require_command codex

  if [[ ! -x "$USAGE_SCRIPT" ]]; then
    echo "Missing executable usage helper: $USAGE_SCRIPT" >&2
    exit 1
  fi

  case "$command" in
    install)
      install_bootstrap_agent
      schedule_next_fire
      ;;
    schedule)
      schedule_next_fire
      ;;
    run)
      run_and_reschedule
      ;;
  esac
}

main "$@"
