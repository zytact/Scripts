#!/usr/bin/env bash

STEPS=("dnf" "flatpak" "snap" "npm" "pnpm" "bun" "rustup" "cargo" "uv" "opencode" "pi" "codex")

run_step() {
  case "$1" in
    dnf)      sudo dnf upgrade -y ;;
    flatpak)  flatpak update -y ;;
    snap)     sudo snap refresh ;;
    npm)      npm -g update ;;
    pnpm)     npm install -g pnpm@latest-10 && pnpm -g update ;;
    bun)      bun upgrade && bun -g update ;;
    rustup)   rustup update ;;
    cargo)    cargo update ;;
    uv)       uv self update ;;
    opencode) opencode upgrade ;;
    pi)       pi update ;;
    codex)    codex update ;;
  esac
}

if command -v gum &>/dev/null; then
  selected=$(printf '%s\n' "${STEPS[@]}" | gum choose --no-limit --selected="$(IFS=,; echo "${STEPS[*]}")")
else
  echo "[warning] gum not found, running all steps"
  selected=$(printf '%s\n' "${STEPS[@]}")
fi

for step in "${STEPS[@]}"; do
  if printf '%s\n' "$selected" | grep -qx "$step"; then
    run_step "$step"
  else
    echo "[skipped] $step"
  fi
done
