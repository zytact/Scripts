#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
USAGE_SCRIPT="$SCRIPT_DIR/codex-usage"

OFFSET_SECONDS="${OFFSET_SECONDS:-120}"
UNIT_NAME="${UNIT_NAME:-codex-lock-window}"
MESSAGE="${1:-Hi}"
RUNNER_SCRIPT="${RUNNER_SCRIPT:-$SCRIPT_DIR/${UNIT_NAME}-run.sh}"

if ! command -v systemd-run >/dev/null 2>&1; then
  echo "Missing systemd-run." >&2
  exit 1
fi

if ! command -v systemctl >/dev/null 2>&1; then
  echo "Missing systemctl." >&2
  exit 1
fi

if [[ ! -x "$USAGE_SCRIPT" ]]; then
  echo "Missing executable usage helper: $USAGE_SCRIPT" >&2
  exit 1
fi

usage_json="$("$USAGE_SCRIPT" --json)"
primary_reset_at_epoch="$(jq -r '.rate_limit.primary_window.reset_at_epoch // empty' <<<"$usage_json")"

if [[ -z "$primary_reset_at_epoch" ]]; then
  echo "Could not determine 5h window reset time." >&2
  exit 1
fi

schedule_epoch=$(( primary_reset_at_epoch + OFFSET_SECONDS ))
now_epoch="$(date +%s)"

if (( schedule_epoch <= now_epoch )); then
  echo "Computed schedule time is already in the past." >&2
  echo "Reset epoch: $primary_reset_at_epoch" >&2
  echo "Schedule epoch: $schedule_epoch" >&2
  exit 1
fi

schedule_at="$(date -d "@$schedule_epoch" '+%Y-%m-%d %H:%M:%S')"
log_file="${XDG_STATE_HOME:-$HOME/.local/state}/codex-lock-window.log"
mkdir -p "$(dirname "$log_file")"

runner_body=$(cat <<EOF
#!/usr/bin/env bash
set -euo pipefail

mkdir -p "$(dirname "$log_file")"

{
  printf '[%s] Sending auto-lock message: %s\n' "\$(date '+%F %T')" $(printf '%q' "$MESSAGE")
  codex exec --skip-git-repo-check --cd "$HOME" --ephemeral $(printf '%q' "$MESSAGE")
  sleep 10
  printf '[%s] Refreshing next auto-lock timer\n' "\$(date '+%F %T')"
  $(printf '%q' "$SCRIPT_DIR/codex-lock-window") $(printf '%q' "$MESSAGE")
} >> $(printf '%q' "$log_file") 2>&1
EOF
)

if [[ ! -f "$RUNNER_SCRIPT" ]] || [[ "$(cat "$RUNNER_SCRIPT" 2>/dev/null)" != "$runner_body" ]]; then
  printf '%s\n' "$runner_body" > "$RUNNER_SCRIPT"
  chmod +x "$RUNNER_SCRIPT"
fi

systemctl --user stop "${UNIT_NAME}.timer" >/dev/null 2>&1 || true
systemctl --user stop "${UNIT_NAME}.service" >/dev/null 2>&1 || true
systemctl --user reset-failed "${UNIT_NAME}.timer" "${UNIT_NAME}.service" >/dev/null 2>&1 || true

systemd-run \
  --user \
  --unit="$UNIT_NAME" \
  --on-calendar="$schedule_at" \
  --description="Send a Codex keepalive message after the 5h window resets" \
  "$RUNNER_SCRIPT"

echo "Scheduled Codex auto-lock at $schedule_at"
echo "Message: $MESSAGE"
echo "Runner: $RUNNER_SCRIPT"
echo "Log: $log_file"
