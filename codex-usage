#!/usr/bin/env bash
set -euo pipefail

MODE="pretty"
REPORT="usage"

usage() {
  cat <<'EOF'
Usage: codex-usage [--json|--shell] [--resets]

Options:
  --json    Print machine-readable JSON instead of the formatted dashboard
  --shell   Print shell-friendly KEY=VALUE lines
  --resets  Show available reset credits and exact expiry times
  -h, --help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      MODE="json"
      shift
      ;;
    --shell)
      MODE="shell"
      shift
      ;;
    --resets|--reset-credits)
      REPORT="resets"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

AUTH_FILE="${CODEX_HOME:-$HOME/.codex}/auth.json"

if ! command -v jq >/dev/null 2>&1; then
  echo "Missing jq. Install it:"
  echo "  sudo dnf install jq"
  exit 1
fi

if [[ ! -f "$AUTH_FILE" ]]; then
  echo "Codex auth file not found: $AUTH_FILE"
  exit 1
fi

# Colors
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'
RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
CYAN=$'\033[36m'
WHITE=$'\033[37m'

BRIGHT_RED=$'\033[91m'
BRIGHT_GREEN=$'\033[92m'
BRIGHT_YELLOW=$'\033[93m'
BRIGHT_BLUE=$'\033[94m'
BRIGHT_MAGENTA=$'\033[95m'
BRIGHT_CYAN=$'\033[96m'

ACCESS_TOKEN="$(jq -r '
  .tokens.access_token
  // .tokens.access
  // .access_token
  // .access
  // .chatgptAuthTokens.access_token
  // .chatgpt_auth.access_token
  // empty
' "$AUTH_FILE")"

ACCOUNT_ID="$(jq -r '
  .account_id
  // .accountId
  // .tokens.account_id
  // .tokens.accountId
  // .chatgpt_account_id
  // .chatgptAccountId
  // empty
' "$AUTH_FILE")"

if [[ -z "$ACCESS_TOKEN" || "$ACCESS_TOKEN" == "null" ]]; then
  echo "Could not find access token in $AUTH_FILE"
  exit 1
fi

fmt_eta() {
  local seconds="$1"

  if [[ -z "$seconds" || "$seconds" == "null" ]]; then
    echo "unknown"
    return
  fi

  seconds="${seconds%.*}"

  if (( seconds <= 0 )); then
    echo "resetting now"
    return
  fi

  local d=$(( seconds / 86400 ))
  local h=$(( (seconds % 86400) / 3600 ))
  local m=$(( (seconds % 3600) / 60 ))

  if (( d > 0 )); then
    echo "${d}d ${h}h ${m}m"
  elif (( h > 0 )); then
    echo "${h}h ${m}m"
  else
    echo "${m}m"
  fi
}

fmt_abs_time_from_reset_seconds() {
  local seconds="$1"

  if [[ -z "$seconds" || "$seconds" == "null" ]]; then
    echo "unknown"
    return
  fi

  seconds="${seconds%.*}"
  local target=$(( $(date +%s) + seconds ))

  date -d "@$target" "+%a, %d %b %I:%M %p" 2>/dev/null \
    || date -r "$target" "+%a, %d %b %I:%M %p"
}

usage_color() {
  local used="${1%.*}"

  if (( used < 40 )); then
    echo "$BRIGHT_GREEN"
  elif (( used < 70 )); then
    echo "$BRIGHT_YELLOW"
  elif (( used < 90 )); then
    echo "$YELLOW"
  else
    echo "$BRIGHT_RED"
  fi
}

bar() {
  local used="${1%.*}"
  local width=24
  local filled=$(( used * width / 100 ))
  local empty=$(( width - filled ))
  local color
  color="$(usage_color "$used")"

  printf "%s" "$color"
  printf "%0.s█" $(seq 1 "$filled" 2>/dev/null)
  printf "%s" "$DIM"
  printf "%0.s░" $(seq 1 "$empty" 2>/dev/null)
  printf "%s" "$RESET"
}

fetch_usage() {
  local url="$1"

  if [[ -n "$ACCOUNT_ID" && "$ACCOUNT_ID" != "null" ]]; then
    curl -fsS "$url" \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "chatgpt-account-id: $ACCOUNT_ID" \
      -H "accept: application/json"
  else
    curl -fsS "$url" \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "accept: application/json"
  fi
}

fetch_reset_credits() {
  local url="https://chatgpt.com/backend-api/wham/rate-limit-reset-credits"

  if [[ -n "$ACCOUNT_ID" && "$ACCOUNT_ID" != "null" ]]; then
    curl -fsS "$url" \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "chatgpt-account-id: $ACCOUNT_ID" \
      -H "accept: application/json" \
      -H "OpenAI-Beta: codex-1" \
      -H "User-Agent: codex-usage/1.0" \
      -H "originator: Codex Desktop"
  else
    curl -fsS "$url" \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "accept: application/json" \
      -H "OpenAI-Beta: codex-1" \
      -H "User-Agent: codex-usage/1.0" \
      -H "originator: Codex Desktop"
  fi
}

parse_time_to_epoch() {
  local value="$1"

  if [[ -z "$value" || "$value" == "null" ]]; then
    echo ""
    return
  fi

  if [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    value="${value%.*}"
    if (( value > 100000000000 )); then
      echo $(( value / 1000 ))
    else
      echo "$value"
    fi
    return
  fi

  date -d "$value" +%s 2>/dev/null && return

  local bsd_value="${value/Z/+0000}"
  if [[ "$bsd_value" =~ ^(.*T[0-9]{2}:[0-9]{2}:[0-9]{2})\.[0-9]+([+-][0-9]{2}:?[0-9]{2})$ ]]; then
    bsd_value="${BASH_REMATCH[1]}${BASH_REMATCH[2]}"
  fi
  if [[ "$bsd_value" =~ ^(.*)([+-][0-9]{2}):([0-9]{2})$ ]]; then
    bsd_value="${BASH_REMATCH[1]}${BASH_REMATCH[2]}${BASH_REMATCH[3]}"
  fi
  date -j -f "%Y-%m-%dT%H:%M:%S%z" "$bsd_value" +%s 2>/dev/null || echo ""
}

fmt_abs_time_from_epoch() {
  local epoch="$1"

  if [[ -z "$epoch" || "$epoch" == "null" ]]; then
    echo "unknown"
    return
  fi

  date -d "@$epoch" "+%Y-%m-%d %I:%M:%S %p %Z" 2>/dev/null \
    || date -r "$epoch" "+%Y-%m-%d %I:%M:%S %p %Z"
}

TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT

if [[ "$REPORT" == "resets" ]]; then
  if ! fetch_reset_credits > "$TMP"; then
    echo "Reset credits request failed."
    exit 1
  fi

  RESET_COUNT="$(jq -r '(.available_count // ((.credits // .data // .items // []) | length))' "$TMP")"
  RESET_LABEL="resets"
  [[ "$RESET_COUNT" == "1" ]] && RESET_LABEL="reset"
  now_epoch="$(date +%s)"

  if [[ "$MODE" == "json" ]]; then
    jq -n \
      --argjson now_epoch "$now_epoch" \
      --argjson available_count "$RESET_COUNT" \
      --slurpfile payload "$TMP" \
      '{
        now_epoch: $now_epoch,
        available_count: $available_count,
        credits: (($payload[0].credits // $payload[0].data // $payload[0].items // []) | map({
          expires_at: (.expires_at // .expiresAt // .expiry // .expires // .expiration // .expiration_at // null)
        }))
      }'
    exit 0
  fi

  if [[ "$MODE" == "shell" ]]; then
    echo "NOW_EPOCH=$now_epoch"
    echo "RESET_CREDITS_AVAILABLE=$RESET_COUNT"

    index=1
    while IFS=$'\t' read -r expires; do
      epoch="$(parse_time_to_epoch "$expires")"
      echo "RESET_${index}_EXPIRES_RAW=$expires"
      echo "RESET_${index}_EXPIRES_EPOCH=$epoch"
      index=$(( index + 1 ))
    done < <(jq -r '
      (.credits // .data // .items // [])[]
      | (.expires_at // .expiresAt // .expiry // .expires // .expiration // .expiration_at // "")
    ' "$TMP")
    exit 0
  fi

  printf '\n'
  echo "${BOLD}${BRIGHT_CYAN}╔══════════════════════════════╗${RESET}"
  echo "${BOLD}${BRIGHT_CYAN}║      CODEX RESET CREDITS     ║${RESET}"
  echo "${BOLD}${BRIGHT_CYAN}╚══════════════════════════════╝${RESET}"
  echo "  ${DIM}$(date '+%a, %d %b %Y %I:%M %p %Z')${RESET}"
  echo
  echo "  ${DIM}Available${RESET} ${BRIGHT_GREEN}${BOLD}${RESET_COUNT} ${RESET_LABEL}${RESET}"
  echo

  if (( RESET_COUNT == 0 )); then
    echo "${BRIGHT_YELLOW}No reset credits found.${RESET}"
    exit 0
  fi

  printf "  ${DIM}%-4s %-24s %-14s${RESET}\n" "#" "Expires" "Time left"
  printf "  ${DIM}%-4s %-24s %-14s${RESET}\n" "----" "------------------------" "--------------"

  index=1
  while IFS=$'\t' read -r expires; do
    epoch="$(parse_time_to_epoch "$expires")"
    time_left="unknown"
    if [[ -n "$epoch" ]]; then
      time_left="$(fmt_eta "$(( epoch - now_epoch ))")"
    fi
    printf "  ${BOLD}%-4s${RESET} ${BRIGHT_BLUE}%-24s${RESET} ${BRIGHT_GREEN}%-14s${RESET}\n" \
      "$index" "$(fmt_abs_time_from_epoch "$epoch")" "$time_left"
    index=$(( index + 1 ))
  done < <(jq -r '
    (.credits // .data // .items // [])[]
    | (.expires_at // .expiresAt // .expiry // .expires // .expiration // .expiration_at // "")
  ' "$TMP")

  echo
  exit 0
fi

if ! fetch_usage "https://chatgpt.com/backend-api/wham/usage" > "$TMP"; then
  if ! fetch_usage "https://chatgpt.com/backend-api/codex/usage" > "$TMP"; then
    echo "Usage request failed."
    exit 1
  fi
fi

PRIMARY_USED="$(jq -r '.rate_limit.primary_window.used_percent // empty' "$TMP")"
SECONDARY_USED="$(jq -r '.rate_limit.secondary_window.used_percent // empty' "$TMP")"

PRIMARY_RESET_SECONDS="$(jq -r '
  .rate_limit.primary_window.reset_after_seconds
  // (
    if .rate_limit.primary_window.reset_at then
      (
        (
          if .rate_limit.primary_window.reset_at > 100000000000
          then .rate_limit.primary_window.reset_at / 1000
          else .rate_limit.primary_window.reset_at
          end
        ) - now
      )
    else empty end
  )
' "$TMP")"

SECONDARY_RESET_SECONDS="$(jq -r '
  .rate_limit.secondary_window.reset_after_seconds
  // (
    if .rate_limit.secondary_window.reset_at then
      (
        (
          if .rate_limit.secondary_window.reset_at > 100000000000
          then .rate_limit.secondary_window.reset_at / 1000
          else .rate_limit.secondary_window.reset_at
          end
        ) - now
      )
    else empty end
  )
' "$TMP")"

LIMIT_REACHED="$(jq -r '.rate_limit.limit_reached // false' "$TMP")"
ALLOWED="$(jq -r '.rate_limit.allowed // true' "$TMP")"

now_epoch="$(date +%s)"

normalize_seconds() {
  local seconds="${1:-}"

  if [[ -z "$seconds" || "$seconds" == "null" ]]; then
    echo ""
    return
  fi

  printf '%s\n' "${seconds%.*}"
}

PRIMARY_RESET_SECONDS="$(normalize_seconds "$PRIMARY_RESET_SECONDS")"
SECONDARY_RESET_SECONDS="$(normalize_seconds "$SECONDARY_RESET_SECONDS")"

PRIMARY_RESET_AT_EPOCH=""
SECONDARY_RESET_AT_EPOCH=""

if [[ -n "$PRIMARY_RESET_SECONDS" ]]; then
  PRIMARY_RESET_AT_EPOCH=$(( now_epoch + PRIMARY_RESET_SECONDS ))
fi

if [[ -n "$SECONDARY_RESET_SECONDS" ]]; then
  SECONDARY_RESET_AT_EPOCH=$(( now_epoch + SECONDARY_RESET_SECONDS ))
fi

if [[ "$MODE" == "json" ]]; then
  jq -n \
    --argjson now_epoch "$now_epoch" \
    --argjson limit_reached "$( [[ "$LIMIT_REACHED" == "true" ]] && echo true || echo false )" \
    --argjson allowed "$( [[ "$ALLOWED" == "true" ]] && echo true || echo false )" \
    --arg primary_used "${PRIMARY_USED:-}" \
    --arg secondary_used "${SECONDARY_USED:-}" \
    --arg primary_reset_seconds "${PRIMARY_RESET_SECONDS:-}" \
    --arg secondary_reset_seconds "${SECONDARY_RESET_SECONDS:-}" \
    --arg primary_reset_at_epoch "${PRIMARY_RESET_AT_EPOCH:-}" \
    --arg secondary_reset_at_epoch "${SECONDARY_RESET_AT_EPOCH:-}" \
    '{
      now_epoch: $now_epoch,
      limit_reached: $limit_reached,
      allowed: $allowed,
      rate_limit: {
        primary_window: {
          used_percent: ($primary_used | if . == "" then null else (tonumber? // .) end),
          reset_after_seconds: ($primary_reset_seconds | if . == "" then null else (tonumber? // .) end),
          reset_at_epoch: ($primary_reset_at_epoch | if . == "" then null else (tonumber? // .) end)
        },
        secondary_window: {
          used_percent: ($secondary_used | if . == "" then null else (tonumber? // .) end),
          reset_after_seconds: ($secondary_reset_seconds | if . == "" then null else (tonumber? // .) end),
          reset_at_epoch: ($secondary_reset_at_epoch | if . == "" then null else (tonumber? // .) end)
        }
      }
    }'
  exit 0
fi

if [[ "$MODE" == "shell" ]]; then
  cat <<EOF
NOW_EPOCH=$now_epoch
LIMIT_REACHED=$LIMIT_REACHED
ALLOWED=$ALLOWED
PRIMARY_USED=${PRIMARY_USED:-}
PRIMARY_RESET_SECONDS=${PRIMARY_RESET_SECONDS:-}
PRIMARY_RESET_AT_EPOCH=${PRIMARY_RESET_AT_EPOCH:-}
SECONDARY_USED=${SECONDARY_USED:-}
SECONDARY_RESET_SECONDS=${SECONDARY_RESET_SECONDS:-}
SECONDARY_RESET_AT_EPOCH=${SECONDARY_RESET_AT_EPOCH:-}
EOF
  exit 0
fi

print_window() {
  local title="$1"
  local used="$2"
  local reset_seconds="$3"

  [[ -z "$used" ]] && return

  local used_round
  local color
  used_round="$(awk "BEGIN { printf \"%.0f\", $used }")"
  color="$(usage_color "$used_round")"

  echo "${BOLD}${BRIGHT_MAGENTA}╭──────────────────────────────╮${RESET}"
  printf "${BOLD}${BRIGHT_MAGENTA}│${RESET} ${BOLD}${BRIGHT_CYAN}%-28s${RESET} ${BOLD}${BRIGHT_MAGENTA}│${RESET}\n" "$title"
  echo "${BOLD}${BRIGHT_MAGENTA}╰──────────────────────────────╯${RESET}"

  echo "  ${DIM}Usage${RESET}   $(bar "$used_round")  ${color}${BOLD}${used_round}% used${RESET}"
  echo "  ${DIM}Reset${RESET}   ${BRIGHT_GREEN}in $(fmt_eta "$reset_seconds")${RESET}"
  echo "  ${DIM}At${RESET}      ${BRIGHT_BLUE}$(fmt_abs_time_from_reset_seconds "$reset_seconds")${RESET}"
  echo
}

printf '\n'
echo "${BOLD}${BRIGHT_CYAN}╔══════════════════════════════╗${RESET}"
echo "${BOLD}${BRIGHT_CYAN}║        CODEX  USAGE          ║${RESET}"
echo "${BOLD}${BRIGHT_CYAN}╚══════════════════════════════╝${RESET}"
echo "  ${DIM}$(date '+%a, %d %b %Y %I:%M %p')${RESET}"
echo

if [[ "$LIMIT_REACHED" == "true" || "$ALLOWED" == "false" ]]; then
  echo "${BOLD}${BRIGHT_RED}⚠ LIMIT REACHED${RESET}"
  echo
fi

if [[ -z "$PRIMARY_USED" && -z "$SECONDARY_USED" ]]; then
  echo "${BRIGHT_RED}No usage windows found.${RESET}"
  exit 1
fi

print_window "5h window" "$PRIMARY_USED" "$PRIMARY_RESET_SECONDS"
print_window "7d window" "$SECONDARY_USED" "$SECONDARY_RESET_SECONDS"
