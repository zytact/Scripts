def emit_html_report(
    scope_title: str,
    combined_stats: dict,
    codex_stats: dict,
    t3code_stats: dict,
    codex_other_stats: dict,
    opencode_stats: dict,
    opencode_t3code_stats: dict,
    opencode_other_stats: dict,
    claude_stats: dict,
    pi_stats: dict,
) -> None:
    doc = render_html_document(
        scope_title,
        combined_stats,
        codex_stats,
        t3code_stats,
        codex_other_stats,
        opencode_stats,
        opencode_t3code_stats,
        opencode_other_stats,
        claude_stats,
        pi_stats,
    )
    if OUTPUT_PATH == "-":
        print(doc)
        return
    if not OUTPUT_PATH:
        raise SystemExit("missing html output path")
    output = Path(OUTPUT_PATH).expanduser()
    if output.parent != Path(""):
        output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(doc, encoding="utf-8")


all_sessions = collect_sessions()
PRICING_MAP = load_pricing_map()
start = scope_start(SCOPE)
filtered = filter_sessions(all_sessions, start)
codex_sessions = [s for s in filtered if s["source"] == "codex"]
t3code_sessions = [s for s in codex_sessions if s.get("originator") == "t3code_desktop"]
codex_other_sessions = [s for s in codex_sessions if s.get("originator") != "t3code_desktop"]
claude_sessions = [s for s in filtered if s["source"] == "claude"]
opencode_sessions_filtered = [s for s in filtered if s["source"] == "opencode"]
opencode_t3code_sessions = [s for s in opencode_sessions_filtered if s.get("originator") == "t3code_desktop"]
opencode_other_sessions = [s for s in opencode_sessions_filtered if s.get("originator") != "t3code_desktop"]
pi_sessions = [s for s in filtered if s["source"] == "pi"]
combined = aggregate(filtered)
codex = aggregate(codex_sessions)
t3code = aggregate(t3code_sessions)
codex_other = aggregate(codex_other_sessions)
opencode = aggregate(opencode_sessions_filtered)
opencode_t3code = aggregate(opencode_t3code_sessions)
opencode_other = aggregate(opencode_other_sessions)
claude = aggregate(claude_sessions)
pi = aggregate(pi_sessions)

scope_title = {
    "today": f"Today · {TODAY.isoformat()}",
    "7d": f"Last 7 Days · since {(TODAY - dt.timedelta(days=6)).isoformat()}",
    "30d": f"Last 30 Days (rolling) · since {(TODAY - dt.timedelta(days=29)).isoformat()}",
}[SCOPE]

if OUTPUT_MODE == "html":
    emit_html_report(scope_title, combined, codex, t3code, codex_other, opencode, opencode_t3code, opencode_other, claude, pi)
else:
    print_banner(scope_title, combined)
    print_section("Combined", "95", combined)
    print_section("Codex", "94", codex)
    print_section("Codex via T3 Code", "33", t3code)
    print_section("Codex other", "36", codex_other)
    print_section("opencode", "95", opencode)
    print_section("opencode via T3 Code", "33", opencode_t3code)
    print_section("opencode other", "36", opencode_other)
    if INCLUDE_CLAUDE:
        print_section("Claude Code", "35", claude)
    print_section("Pi", "92", pi)

    print(color("HIGHLIGHTS", "1;93"))
    if filtered:
        longest = max(filtered, key=lambda s: s["active_seconds"])
        print(
            f"  {color('Longest active', '93')}  {bold(session_label(longest))} {dim('·')} "
            f"{color(human_seconds(longest['active_seconds']), '1;97')} {dim('·')} {color(longest['repo'], '96')}"
        )
        latest = max(filtered, key=lambda s: s["end"])
        print(
            f"  {color('Latest session', '95')}  {bold(session_label(latest))} {dim('·')} "
            f"{color(latest['end'].strftime('%b %d %I:%M %p'), '1;97')} {dim('·')} {color(latest['repo'], '96')}"
        )
    else:
        print(f"  {dim('No sessions found in this range.')}")
PY
}

show_sources() {
  local include_claude="$1"
  gum style --foreground 212 --bold "Session stores found locally"
  printf "\n"
  gum style --foreground 99 "Codex" && printf "  ~/.codex/sessions and ~/.codex/history.jsonl\n"
  gum style --foreground 214 "T3 Code" && printf "  detected inside Codex meta (originator=t3code_desktop) and opencode titles (T3 Code*)\n"
  gum style --foreground 213 "opencode" && printf "  ~/.local/share/opencode/opencode.db\n"
  if [[ "$include_claude" == "1" ]]; then
    gum style --foreground 35 "Claude Code" && printf "  ~/.claude/projects\n"
  fi
  gum style --foreground 86 "Pi" && printf "  ~/.pi/agent/sessions (resolved from your ~/.pi symlink)\n"
  printf "\n"
  gum style --faint "This dashboard reads local JSONL session history directly."
}

pick_scope() {
  gum choose \
    --header "Pick a time range (explicitly rolling for 7d and 30d)" \
    "today" \
    "7d" \
    "30d"
}

open_html_report() {
  local scope="$1"
  local output_path="$2"
  local should_open="$3"

  render_report "$scope" "$INCLUDE_CLAUDE" html "$output_path"
  if [[ "$output_path" != "-" ]]; then
    printf "HTML report: %s\n" "$output_path"
  fi
  if [[ "$should_open" == "1" && "$output_path" != "-" ]]; then
    if command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$output_path" >/dev/null 2>&1 &
    else
      printf "xdg-open not found. Open this file manually.\n"
    fi
  fi
}

if [[ -n "$SCOPE_ARG" ]]; then
  scope="$SCOPE_ARG"
else
  scope="$(pick_scope)" || exit 0
fi

if [[ "$HTML_MODE" == "1" ]]; then
  if [[ -z "$HTML_PATH" ]]; then
    HTML_PATH="$(mktemp "${TMPDIR:-/tmp}/agent-usage-report.XXXXXX.html")"
  fi
  if [[ "$HTML_PATH_SET" == "1" ]]; then
    open_html_report "$scope" "$HTML_PATH" 0
  else
    open_html_report "$scope" "$HTML_PATH" 1
  fi
  exit 0
fi

while true; do
  clear
  show_sources "$INCLUDE_CLAUDE"
  printf "\n"
  render_report "$scope" "$INCLUDE_CLAUDE"
  printf "\n"
  action="$(gum choose \
    --header "Choose an action" \
    "Open HTML report" \
    "Change range" \
    "Refresh" \
    "Exit")" || exit 0

  case "$action" in
    "Open HTML report")
      output_path="$(mktemp "${TMPDIR:-/tmp}/agent-usage-report.XXXXXX.html")"
      open_html_report "$scope" "$output_path" 1
      printf "Press enter to continue..."
      read -r _
      ;;
    "Change range")
      scope="$(pick_scope)" || exit 0
      ;;
    "Refresh")
      ;;
    "Exit")
      exit 0
      ;;
  esac
done
