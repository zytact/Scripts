def h(value) -> str:
    return escape(str(value), quote=True)


def css_pct(value: int, max_value: int) -> str:
    if max_value <= 0:
        return "0%"
    pct = max(0, min(100, (value / max_value) * 100))
    if value > 0 and pct < 2:
        pct = 2
    return f"{pct:.1f}%"


def slug(value: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-") or "source"


def html_metric(label: str, value: str, note: str = "") -> str:
    note_html = f"<span>{h(note)}</span>" if note else ""
    return f"""
      <div class="metric">
        <dt>{h(label)}</dt>
        <dd>{h(value)}</dd>
        {note_html}
      </div>"""


def html_token_bar(label: str, value: int, max_value: int, class_name: str) -> str:
    return f"""
      <div class="token-row {h(class_name)}">
        <span>{h(label)}</span>
        <div class="track" aria-hidden="true"><i style="width:{css_pct(value, max_value)}"></i></div>
        <b>{h(compact_tokens(value))}</b>
      </div>"""


def html_simple_list(title: str, rows: list[tuple[str, str]], empty: str = "No data") -> str:
