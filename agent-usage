    ".toml": "TOML",
    ".yaml": "YAML",
    ".yml": "YAML",
    ".md": "Markdown",
    ".html": "HTML",
    ".css": "CSS",
    ".scss": "SCSS",
    ".sql": "SQL",
    ".lua": "Lua",
    ".rb": "Ruby",
    ".php": "PHP",
    ".swift": "Swift",
