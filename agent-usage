def collect_sessions():
    sessions = []
    for path in iter_jsonl_files(CODEX_DIR):
        stat = codex_session_stats(path)
        if stat:
            sessions.append(stat)
    sessions.extend(opencode_sessions())
    if INCLUDE_CLAUDE:
        for path in iter_jsonl_files(CLAUDE_DIR):
            stat = claude_session_stats(path)
            if stat:
                sessions.append(stat)
    for path in iter_jsonl_files(PI_DIR):
        stat = pi_session_stats(path)
        if stat:
            sessions.append(stat)
    return sessions


def filter_sessions(sessions, start):
    return [s for s in sessions if s["end"] >= start]


def human_seconds(total: int) -> str:
    hours, rem = divmod(total, 3600)
    mins, _ = divmod(rem, 60)
    if hours:
        return f"{hours}h {mins}m"
    return f"{mins}m"


def compact_tokens(value: int) -> str:
    if value >= 1_000_000:
        return f"{value / 1_000_000:.2f}M"
    if value >= 1_000:
        return f"{value / 1_000:.1f}k"
    return str(value)


def color(text: str, code: str) -> str:
    return f"\033[{code}m{text}\033[0m"


def dim(text: str) -> str:
    return color(text, "2")


def bold(text: str) -> str:
    return color(text, "1")


def visible_len(text: str) -> int:
    return len(text)


def framed_line(text: str, width: int, border_color: str, text_color: str | None = None) -> str:
    shown = color(text, text_color) if text_color else text
    padding = max(0, width - visible_len(text))
    return color("║", border_color) + " " + shown + (" " * padding) + color("║", border_color)


def bar(value: int, max_value: int, width: int = 22, color_code: str = "96") -> str:
    if max_value <= 0:
        filled = 0
    else:
        filled = round((value / max_value) * width)
    if value > 0 and filled == 0:
        filled = 1
    filled = max(0, min(width, filled))
    empty = width - filled
    return color("█" * filled, color_code) + dim("░" * empty)


def metric_line(label: str, value: str, accent: str = "97") -> str:
    return f"  {dim(label.ljust(14))} {color(value, accent)}"


def list_block(title: str, rows: list[tuple[str, str]], accent: str) -> list[str]:
    out = [f"  {color(title, accent)}"]
    if not rows:
        out.append(f"    {dim('none')}")
        return out
    max_value = max((len(value) for _, value in rows), default=1)
    for name, value in rows:
        out.append(f"    {color('•', accent)} {bold(name)} {dim('·')} {color(value, '97')}")
    return out


def percent_rows(counter: Counter, limit: int = 5) -> list[tuple[str, str]]:
