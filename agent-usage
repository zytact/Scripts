def load_pricing_map():
    try:
        req = urllib.request.Request(MODELS_DEV_URL, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=20) as response:
            payload = json.load(response)
    except Exception:
        return {}

    out = {}
    for item in payload.get("data", []):
        if not isinstance(item, dict):
            continue
        pricing = item.get("pricing") or {}
        if not isinstance(pricing, dict):
            pricing = {}
        out[str(item.get("id"))] = {
            "name": item.get("name") or item.get("id"),
            "prompt": pricing.get("prompt"),
            "completion": pricing.get("completion"),
            "cache_read": pricing.get("input_cache_read"),
            "cache_write": pricing.get("input_cache_write"),
        }
    return out


def as_decimal(value):
    if value in (None, "", "null"):
        return None
    try:
        return Decimal(str(value))
    except (InvalidOperation, ValueError):
        return None


def estimate_cost_breakdown_usd(model_name: str, token_info: dict, pricing_map: dict) -> dict | None:
    model_id = MODEL_ALIASES.get(model_name, model_name)
    pricing = pricing_map.get(model_id)
    if not pricing:
        return None
    prompt = as_decimal(pricing.get("prompt")) or Decimal("0")
    completion = as_decimal(pricing.get("completion")) or Decimal("0")
    cache_read = as_decimal(pricing.get("cache_read")) or Decimal("0")
    cache_write = as_decimal(pricing.get("cache_write")) or prompt
    input_tokens = Decimal(token_info.get("input", 0) or 0)
    output_tokens = Decimal(token_info.get("output", 0) or 0)
    cached_tokens = Decimal(token_info.get("cached", 0) or 0)
    cache_write_tokens = Decimal(token_info.get("cache_write", 0) or 0)
    input_cost = input_tokens * prompt
    cache_cost = cached_tokens * cache_read
    cache_write_cost = cache_write_tokens * cache_write
    output_cost = output_tokens * completion
    total_cost = input_cost + cache_cost + cache_write_cost + output_cost
    return {
        "input": input_cost,
        "cached": cache_cost,
        "cache_write": cache_write_cost,
        "output": output_cost,
        "total": total_cost,
    }


def usd(value: Decimal | None) -> str:
    if value is None:
        return "n/a"
    if value == 0:
        return "$0.00"
    if value < Decimal("0.01"):
        return f"${value:.4f}"
    return f"${value:.2f}"


def usd_per_million(value: Decimal | None) -> str:
    if value is None:
        return "n/a"
    per_million = value * Decimal("1000000")
    if per_million == 0:
        return "$0/M"
    if per_million < Decimal("0.01"):
        return f"${per_million:.4f}/M"
    if per_million < Decimal("1"):
        return f"${per_million:.3f}/M"
    return f"${per_million:.2f}/M"


def usage_rows(counter: Counter, limit: int = 5) -> list[tuple[str, str, float]]:
    total = sum(counter.values())
    if total <= 0:
        return []
    rows = []
    for name, count in sorted_top(counter, limit):
        pct = (count / total) * 100
        rows.append((name, f"{pct:.0f}%", pct))
    return rows


def model_rows(stats: dict, pricing_map: dict, limit: int = 5) -> list[tuple[str, str, float]]:
    total = sum(stats["model_usage"].values())
    if total <= 0:
        return []
    rows = []
    for model, count in sorted_top(stats["model_usage"], limit):
        pct = (count / total) * 100
        token_info = stats["model_tokens"].get(model, {})
        model_id = MODEL_ALIASES.get(model, model)
        pricing = pricing_map.get(model_id) or {}
        prompt_rate = usd_per_million(as_decimal(pricing.get("prompt")))
        completion_rate = usd_per_million(as_decimal(pricing.get("completion")))
        costs = estimate_cost_breakdown_usd(model, token_info, pricing_map)
        rows.append((
            model,
            f"{pct:.0f}% · in {compact_tokens(token_info.get('input', 0))} ({prompt_rate})"
            f" · cached {compact_tokens(token_info.get('cached', 0))}"
            f" · write {compact_tokens(token_info.get('cache_write', 0))}"
            f" · out {compact_tokens(token_info.get('output', 0))} ({completion_rate})"
            f" · est {usd(costs['total']) if costs else 'n/a'}",
            pct,
        ))
    return rows


def estimate_stats_total_cost(stats: dict, pricing_map: dict) -> Decimal | None:
    total_cost = Decimal("0")
    found_any = False
    for model_name, token_info in stats.get("model_tokens", {}).items():
        costs = estimate_cost_breakdown_usd(model_name, token_info, pricing_map)
        if not costs:
            continue
        total_cost += costs["total"]
        found_any = True
    return total_cost if found_any else None


def glam_bar_list_block(title: str, rows: list[tuple[str, str, float]], accent: str, glow: str, badge: str, note: str | None = None) -> list[str]:
