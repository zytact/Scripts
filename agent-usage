def parse_ts(value: str) -> dt.datetime | None:
    try:
        return dt.datetime.fromisoformat(value.replace("Z", "+00:00")).astimezone()
    except Exception:
        return None


def parse_epoch_ms(value) -> dt.datetime | None:
    if value in (None, ""):
        return None
    try:
        raw = float(value)
    except (TypeError, ValueError):
        return None
    if raw <= 0:
        return None
    seconds = raw / 1000 if raw > 10_000_000_000 else raw
    try:
        return dt.datetime.fromtimestamp(seconds).astimezone()
    except Exception:
        return None


def scope_start(scope: str) -> dt.datetime:
    if scope == "today":
        return NOW.replace(hour=0, minute=0, second=0, microsecond=0)
    if scope == "7d":
        start_day = TODAY - dt.timedelta(days=6)
        return dt.datetime.combine(start_day, dt.time.min, NOW.tzinfo)
    if scope == "30d":
        start_day = TODAY - dt.timedelta(days=29)
        return dt.datetime.combine(start_day, dt.time.min, NOW.tzinfo)
    raise ValueError(f"unknown scope: {scope}")


def repo_name(cwd: str | None) -> str:
    if not cwd:
        return "unknown"
    parts = Path(cwd).parts
    if "Projects" in parts:
        idx = parts.index("Projects")
        if idx + 1 < len(parts):
            return parts[idx + 1]
    if "dotfiles" in parts:
        idx = parts.index("dotfiles")
        if idx + 1 < len(parts):
            return f"dotfiles/{parts[idx + 1]}"
    return Path(cwd).name or cwd


def infer_languages(text: str) -> Counter:
    counts: Counter[str] = Counter()
    for match in FILE_PATH_RE.findall(text):
        ext = Path(match.strip()).suffix.lower()
        lang = EXTENSION_LANGS.get(ext)
        if lang:
            counts[lang] += 1
    return counts


def merge_counter(target: Counter, source: Counter) -> None:
    for key, value in source.items():
        target[key] += value


def iter_jsonl_files(root: Path):
    if not root.exists():
        return []
    return sorted(root.rglob("*.jsonl"))


def active_seconds(events: list[dt.datetime]) -> int:
    events = sorted(events)
    active = 0
    for prev, cur in zip(events, events[1:]):
        delta = int((cur - prev).total_seconds())
        if delta > 0:
            active += min(delta, ACTIVE_GAP_SECONDS)
    return active or 60


def codex_session_stats(path: Path):
    session_id = None
    cwd = None
    originator = None
    events: list[dt.datetime] = []
    token_total = {"input": 0, "cached": 0, "cache_write": 0, "output": 0, "reasoning": 0, "total": 0}
    langs: Counter[str] = Counter()
    model_counts: Counter[str] = Counter()
    effort_counts: Counter[str] = Counter()

    with path.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            langs.update(infer_languages(line))
            try:
                item = json.loads(line)
            except Exception:
                continue
            if not isinstance(item, dict):
                continue
            ts = parse_ts(item.get("timestamp", ""))
            if ts:
                events.append(ts)
            if item.get("type") == "session_meta":
                payload = item.get("payload") or {}
                if not isinstance(payload, dict):
                    payload = {}
                session_id = payload.get("id")
                cwd = payload.get("cwd")
                originator = payload.get("originator")
            payload = item.get("payload") or {}
            if not isinstance(payload, dict):
                payload = {}
            if item.get("type") == "turn_context":
                model_name = payload.get("model")
                if model_name:
                    model_counts[str(model_name)] += 1
                effort_name = payload.get("effort")
                if effort_name:
                    effort_counts[str(effort_name)] += 1
                collaboration = payload.get("collaboration_mode") or {}
                if isinstance(collaboration, dict):
                    settings = collaboration.get("settings") or {}
                    if isinstance(settings, dict):
                        setting_effort = settings.get("reasoning_effort")
                        if setting_effort and not effort_name:
                            effort_counts[str(setting_effort)] += 1
            if item.get("type") == "event_msg" and payload.get("type") == "token_count":
                info = payload.get("info") or {}
                if not isinstance(info, dict):
                    info = {}
                info = info.get("total_token_usage") or {}
                if not isinstance(info, dict):
                    info = {}
                raw_input_tokens = int(info.get("input_tokens", 0) or 0)
                cached_tokens = int(info.get("cached_input_tokens", 0) or 0)
                input_tokens = max(raw_input_tokens - cached_tokens, 0)
                output_tokens = int(info.get("output_tokens", 0) or 0)
                token_total = {
                    "input": input_tokens,
                    "cached": cached_tokens,
                    "cache_write": 0,
                    "output": output_tokens,
                    "reasoning": int(info.get("reasoning_output_tokens", 0) or 0),
                    "total": input_tokens + cached_tokens + output_tokens,
                }

    if not events:
        return None
    events.sort()
    active = 0
    for prev, cur in zip(events, events[1:]):
        delta = int((cur - prev).total_seconds())
        if delta > 0:
            active += min(delta, ACTIVE_GAP_SECONDS)
    if active == 0:
        active = 60

    model_tokens: dict[str, dict[str, int]] = {}
    total_model_marks = sum(model_counts.values()) or 0
    if total_model_marks > 0:
        for model_name, marks in model_counts.items():
            ratio = marks / total_model_marks
            model_tokens[model_name] = {
                "input": int(token_total.get("input", 0) * ratio),
                "cached": int(token_total.get("cached", 0) * ratio),
                "cache_write": int(token_total.get("cache_write", 0) * ratio),
                "output": int(token_total.get("output", 0) * ratio),
                "total": int(token_total.get("total", 0) * ratio),
            }

    return {
        "source": "codex",
        "source_label": "T3 Code" if originator == "t3code_desktop" else "Codex",
        "session_id": session_id or path.stem,
        "cwd": cwd,
        "repo": repo_name(cwd),
        "originator": originator or "unknown",
        "start": events[0],
        "end": events[-1],
        "active_seconds": active,
        "tokens": token_total,
        "languages": langs,
        "models": model_counts,
        "efforts": effort_counts,
        "model_tokens": model_tokens,
        "path": str(path),
    }


