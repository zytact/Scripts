#!/usr/bin/env bash
set -euo pipefail

if ! command -v python3 >/dev/null 2>&1; then
  echo "Missing python3."
  exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage: agent-usage [--claude] [--scope today|7d|30d] [--html [FILE]]

Options:
  (default)       Include Codex, opencode, and Pi usage from local stores
  --claude       Include Claude Code usage from ~/.claude/projects
  --scope SCOPE  Use a range without prompting: today, 7d, 30d
  --html [FILE]  Write a standalone HTML report. Omit FILE to open a temp report.
                 Use --html=- to print HTML to stdout.
  -h, --help     Show this help
EOF
}

INCLUDE_CLAUDE=0
SCOPE_ARG=""
HTML_MODE=0
HTML_PATH=""
HTML_PATH_SET=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --claude)
      INCLUDE_CLAUDE=1
      shift
      ;;
    --scope)
      [[ $# -ge 2 ]] || { echo "Missing value for --scope" >&2; exit 1; }
      SCOPE_ARG="$2"
      shift 2
      ;;
    --scope=*)
      SCOPE_ARG="${1#--scope=}"
      shift
      ;;
    --html)
      HTML_MODE=1
      if [[ $# -ge 2 && "$2" != --* ]]; then
        HTML_PATH="$2"
        HTML_PATH_SET=1
        shift 2
      else
        shift
      fi
      ;;
    --html=*)
      HTML_MODE=1
      HTML_PATH="${1#--html=}"
      HTML_PATH_SET=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

case "$SCOPE_ARG" in
  ""|today|7d|30d) ;;
  *) echo "Invalid --scope: $SCOPE_ARG" >&2; usage >&2; exit 1 ;;
esac

if [[ "$HTML_MODE" == "0" || -z "$SCOPE_ARG" ]]; then
  if ! command -v gum >/dev/null 2>&1; then
    echo "Missing gum. Install it first."
    exit 1
  fi
fi

