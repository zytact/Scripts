                cache_write_tokens = int(usage.get("cache_creation_input_tokens", 0) or 0)
                output_tokens = int(usage.get("output_tokens", 0) or 0)
                reasoning_tokens = 0
                iterations = usage.get("iterations")
                if isinstance(iterations, list):
                    for iteration in iterations:
                        if not isinstance(iteration, dict):
                            continue
                        reasoning_tokens += int(iteration.get("output_tokens", 0) or 0)
                total_tokens = int(
                    usage.get("total_tokens", 0)
                    or input_tokens + cached_tokens + cache_write_tokens + output_tokens
                )
                tokens["input"] += input_tokens
                tokens["cached"] += cached_tokens
                tokens["cache_write"] += cache_write_tokens
                tokens["output"] += output_tokens
                tokens["reasoning"] += reasoning_tokens
                tokens["total"] += total_tokens
                if model_name and model_name != "<synthetic>":
                    bucket = model_tokens[str(model_name)]
                    bucket["input"] += input_tokens
                    bucket["cached"] += cached_tokens
                    bucket["cache_write"] += cache_write_tokens
                    bucket["output"] += output_tokens
                    bucket["total"] += total_tokens

    if not events:
        return None
    events.sort()
    active = 0
    for prev, cur in zip(events, events[1:]):
        delta = int((cur - prev).total_seconds())
        if delta > 0:
            active += min(delta, ACTIVE_GAP_SECONDS)
    if active == 0:
        active = 60

    return {
        "source": "claude",
        "session_id": session_id or path.stem,
        "cwd": cwd,
