def daily_strip(stats: dict, scope: str) -> str:
    days = {"today": 1, "7d": 7, "30d": 30}[scope]
    start_day = TODAY - dt.timedelta(days=days - 1)
    values = []
    for idx in range(days):
        day = start_day + dt.timedelta(days=idx)
        key = day.isoformat()
        active = int(stats["days"].get(key, {}).get("active_seconds", 0))
        values.append((day, active))
    max_active = max((active for _, active in values), default=1) or 1
    bars = "".join(
        f"<span title=\"{h(day.isoformat() + ': ' + human_seconds(active))}\" "
        f"style=\"height:{css_pct(active, max_active)}\"></span>"
        for day, active in values
    )
    return f"""
      <section class="activity-strip" aria-label="Daily active time">
        <div><h3>Daily active trace</h3><p>Rolling range, scaled to the busiest day in this report.</p></div>
        <div class="bars">{bars}</div>
      </section>"""


