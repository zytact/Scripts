#!/usr/bin/env bash
set -euo pipefail

if ! command -v gum >/dev/null 2>&1; then
  echo "Missing gum. Install it first."
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "Missing python3."
  exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

render_report() {
  local scope="$1"
  python3 - "$scope" <<'PY'
import datetime as dt
import json
import os
import re
import sys
import urllib.request
from collections import Counter, defaultdict
from decimal import Decimal, InvalidOperation
from pathlib import Path

SCOPE = sys.argv[1]
HOME = Path.home()
NOW = dt.datetime.now().astimezone()
TODAY = NOW.date()

CODEX_DIR = HOME / ".codex" / "sessions"
PI_LINK = HOME / ".pi"
PI_HOME = PI_LINK.resolve() if PI_LINK.exists() else PI_LINK
PI_DIR = PI_HOME / "agent" / "sessions"

ACTIVE_GAP_SECONDS = 15 * 60
EXTENSION_LANGS = {
    ".py": "Python",
    ".ts": "TypeScript",
    ".tsx": "TSX",
    ".js": "JavaScript",
    ".jsx": "JSX",
    ".rs": "Rust",
    ".go": "Go",
