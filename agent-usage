def aggregate(sessions):
    data = {
        "active_seconds": 0,
        "session_count": 0,
        "tokens": {"input": 0, "cached": 0, "cache_write": 0, "output": 0, "reasoning": 0, "total": 0},
        "repos": Counter(),
        "languages": Counter(),
        "efforts": Counter(),
        "model_usage": Counter(),
        "model_tokens": defaultdict(lambda: {"input": 0, "cached": 0, "cache_write": 0, "output": 0, "total": 0}),
        "days": defaultdict(lambda: {"active_seconds": 0, "session_count": 0}),
    }
    for session in sessions:
        data["active_seconds"] += session["active_seconds"]
        data["session_count"] += 1
        for key in data["tokens"]:
            data["tokens"][key] += session["tokens"].get(key, 0)
        data["repos"][session["repo"]] += session["active_seconds"]
        merge_counter(data["languages"], session["languages"])
        merge_counter(data["efforts"], session.get("efforts", Counter()))
        session_models = session.get("models", Counter())
        if session_models:
            for model_name, model_marks in session_models.items():
                data["model_usage"][model_name] += model_marks
                bucket = data["model_tokens"][model_name]
                source_bucket = (session.get("model_tokens") or {}).get(model_name, {})
                bucket["input"] += int(source_bucket.get("input", 0) or 0)
                bucket["cached"] += int(source_bucket.get("cached", 0) or 0)
                bucket["cache_write"] += int(source_bucket.get("cache_write", 0) or 0)
                bucket["output"] += int(source_bucket.get("output", 0) or 0)
                bucket["total"] += int(source_bucket.get("total", 0) or 0)
        day_key = session["start"].date().isoformat()
        data["days"][day_key]["active_seconds"] += session["active_seconds"]
        data["days"][day_key]["session_count"] += 1
    return data


