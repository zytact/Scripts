def print_section(title, color_code, stats):
    top_repos = [(name, human_seconds(int(seconds))) for name, seconds in sorted_top(stats["repos"], 4)]
    top_langs = [(name, str(count)) for name, count in sorted_top(stats["languages"], 5)]
    top_days = [
        (day[5:], human_seconds(values["active_seconds"]))
        for day, values in sorted(stats["days"].items(), key=lambda item: item[0], reverse=True)[:4]
    ]
    top_models = model_rows(stats, PRICING_MAP, 4)
    top_efforts = usage_rows(stats["efforts"], 4)
    token_total = max(stats["tokens"]["total"], 1)

    print(color("┏" + "━" * 66 + "┓", color_code))
    print(color("┃", color_code) + f" {color(title.upper(), '1;' + color_code)}" + " " * max(1, 65 - len(title)) + color("┃", color_code))
    print(color("┣" + "━" * 66 + "┫", color_code))
    print(metric_line("Active time", human_seconds(stats["active_seconds"]), "1;97"))
    print(metric_line("Sessions", str(stats["session_count"]), "1;97"))
    print()
    print(f"  {color('Token intensity', color_code)}")
    print(f"    {dim('Scaled against Total tokens in this card, so Total is always the 100% reference bar.')}")
    print(f"    {dim('Input '.ljust(8))} {bar(stats['tokens']['input'], token_total, color_code=color_code)} {color(compact_tokens(stats['tokens']['input']), '97')}")
    print(f"    {dim('Output'.ljust(8))} {bar(stats['tokens']['output'], token_total, color_code='93')} {color(compact_tokens(stats['tokens']['output']), '97')}")
    print(f"    {dim('Total '.ljust(8))} {bar(stats['tokens']['total'], token_total, color_code='95')} {color(compact_tokens(stats['tokens']['total']), '1;97')}")
    print()
    for line in list_block("Top repos", top_repos, color_code):
        print(line)
    print()
    for line in list_block("Languages", top_langs, "92"):
        print(line)
    print()
    for line in glam_bar_list_block(
        "Models",
        top_models,
        "96",
        "1;96",
        "◈",
        "Usage share, per-model token split, and live models.dev rate card.",
    ):
        print(line)
    print()
    for line in glam_bar_list_block(
        "Reasoning effort",
        top_efforts,
        "91",
        "1;91",
        "⬢",
        "Share of turns by reasoning level in this source and range.",
    ):
        print(line)
    print()
    for line in list_block("Daily active", top_days, "93"):
        print(line)
    print(color("┗" + "━" * 66 + "┛", color_code))
    print()


all_sessions = collect_sessions()
PRICING_MAP = load_pricing_map()
start = scope_start(SCOPE)
filtered = filter_sessions(all_sessions, start)
codex_sessions = [s for s in filtered if s["source"] == "codex"]
pi_sessions = [s for s in filtered if s["source"] == "pi"]
combined = aggregate(filtered)
codex = aggregate(codex_sessions)
