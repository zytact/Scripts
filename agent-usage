show_sources() {
  gum style --foreground 212 --bold "Session stores found locally"
  printf "\n"
  gum style --foreground 99 "Codex" && printf "  ~/.codex/sessions and ~/.codex/history.jsonl\n"
  gum style --foreground 86 "Pi" && printf "  ~/.pi/agent/sessions (resolved from your ~/.pi symlink)\n"
  printf "\n"
  gum style --faint "This dashboard reads local JSONL session history directly."
}

pick_scope() {
  gum choose \
    --header "Pick a time range" \
    "today" \
    "7d" \
    "month"
}

scope="$(pick_scope)" || exit 0

while true; do
  clear
  show_sources
  printf "\n"
  render_report "$scope"
  printf "\n"
  action="$(gum choose \
    --header "Choose an action" \
    "Change range" \
    "Refresh" \
    "Exit")" || exit 0

  case "$action" in
    "Change range")
      scope="$(pick_scope)" || exit 0
      ;;
    "Refresh")
      ;;
    "Exit")
      exit 0
      ;;
  esac
done
