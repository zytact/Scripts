def is_t3code_opencode_session(title, metadata) -> bool:
    title_text = str(title or "").strip()
    if re.search(r"^T3 Code(?:\s|$)", title_text, re.IGNORECASE):
        return True
    return "t3code" in str(metadata or "").lower()


def opencode_sessions():
    if not OPENCODE_DB.exists():
        return []

    try:
        conn = sqlite3.connect(f"file:{OPENCODE_DB}?mode=ro", uri=True)
        conn.row_factory = sqlite3.Row
    except sqlite3.Error:
        return []

    try:
        session_rows = conn.execute(
            """
            select id, directory, title, time_created, time_updated, model, metadata,
                   tokens_input, tokens_output, tokens_reasoning,
                   tokens_cache_read, tokens_cache_write
            from session
            """
        ).fetchall()
        message_rows = conn.execute(
            """
            select session_id, time_created, time_updated, data
            from message
            order by session_id, time_created, id
            """
        ).fetchall()
    except sqlite3.Error:
        conn.close()
        return []
    finally:
        try:
            conn.close()
        except sqlite3.Error:
            pass

    grouped_messages: defaultdict[str, list[sqlite3.Row]] = defaultdict(list)
    for row in message_rows:
        grouped_messages[str(row["session_id"])].append(row)

    sessions = []
    for row in session_rows:
        session_id = str(row["id"])
        cwd = row["directory"]
        events = []
        tokens = {"input": 0, "cached": 0, "cache_write": 0, "output": 0, "reasoning": 0, "total": 0}
        langs: Counter[str] = Counter()
        model_counts: Counter[str] = Counter()
        effort_counts: Counter[str] = Counter()
        model_tokens: dict[str, dict[str, int]] = defaultdict(lambda: {"input": 0, "cached": 0, "cache_write": 0, "output": 0, "total": 0})

        for raw_ts in (row["time_created"], row["time_updated"]):
            ts = parse_epoch_ms(raw_ts)
            if ts:
                events.append(ts)

        originator = "t3code_desktop" if is_t3code_opencode_session(row["title"], row["metadata"]) else "opencode"
        fallback_model = None
        try:
            model_info = json.loads(row["model"] or "{}")
        except Exception:
            model_info = {}
        if isinstance(model_info, dict):
            fallback_model = model_info.get("id")
            variant = model_info.get("variant")
            if variant:
                effort_counts[str(variant)] += 1

        if row["title"]:
            langs.update(infer_languages(str(row["title"])))

        diff_path = OPENCODE_DIR / "storage" / "session_diff" / f"{session_id}.json"
        if diff_path.exists():
            try:
                langs.update(infer_languages(diff_path.read_text(encoding="utf-8", errors="ignore")))
            except OSError:
                pass

        for message in grouped_messages.get(session_id, []):
            for raw_ts in (message["time_created"], message["time_updated"]):
                ts = parse_epoch_ms(raw_ts)
                if ts:
                    events.append(ts)
            raw_data = message["data"] or ""
            langs.update(infer_languages(raw_data))
            try:
                data = json.loads(raw_data)
            except Exception:
                continue
            if not isinstance(data, dict):
                continue
            time_info = data.get("time") or {}
            if isinstance(time_info, dict):
                for raw_ts in (time_info.get("created"), time_info.get("completed")):
                    ts = parse_epoch_ms(raw_ts)
                    if ts:
                        events.append(ts)
            path_info = data.get("path") or {}
            if isinstance(path_info, dict):
                cwd = cwd or path_info.get("cwd") or path_info.get("root")
            variant = data.get("variant")
            if variant:
                effort_counts[str(variant)] += 1
            if data.get("role") != "assistant":
                continue
            model_name = data.get("modelID") or fallback_model
            if model_name:
                model_name = str(model_name)
                model_counts[model_name] += 1
            usage = data.get("tokens") or {}
            if not isinstance(usage, dict):
                usage = {}
            cache = usage.get("cache") or {}
            if not isinstance(cache, dict):
                cache = {}
            input_tokens = int(usage.get("input", 0) or 0)
            cached_tokens = int(cache.get("read", 0) or 0)
            cache_write_tokens = int(cache.get("write", 0) or 0)
            output_tokens = int(usage.get("output", 0) or 0)
            reasoning_tokens = int(usage.get("reasoning", 0) or 0)
            total_tokens = int(
                usage.get("total", 0)
                or input_tokens + cached_tokens + cache_write_tokens + output_tokens
            )
            tokens["input"] += input_tokens
            tokens["cached"] += cached_tokens
            tokens["cache_write"] += cache_write_tokens
            tokens["output"] += output_tokens
            tokens["reasoning"] += reasoning_tokens
            tokens["total"] += total_tokens
            if model_name:
                bucket = model_tokens[model_name]
                bucket["input"] += input_tokens
                bucket["cached"] += cached_tokens
                bucket["cache_write"] += cache_write_tokens
                bucket["output"] += output_tokens
                bucket["total"] += total_tokens

        if not events:
            continue

        if tokens["total"] == 0:
            tokens = {
                "input": int(row["tokens_input"] or 0),
                "cached": int(row["tokens_cache_read"] or 0),
                "cache_write": int(row["tokens_cache_write"] or 0),
                "output": int(row["tokens_output"] or 0),
                "reasoning": int(row["tokens_reasoning"] or 0),
                "total": int(row["tokens_input"] or 0)
                + int(row["tokens_cache_read"] or 0)
                + int(row["tokens_cache_write"] or 0)
                + int(row["tokens_output"] or 0),
            }
            if fallback_model:
                model_counts[str(fallback_model)] += 1
                model_tokens[str(fallback_model)] = {
                    "input": tokens["input"],
                    "cached": tokens["cached"],
                    "cache_write": tokens["cache_write"],
                    "output": tokens["output"],
                    "total": tokens["total"],
                }

        sessions.append({
            "source": "opencode",
            "source_label": "T3 Code" if originator == "t3code_desktop" else "opencode",
            "session_id": session_id,
            "cwd": cwd,
            "repo": repo_name(cwd),
            "originator": originator,
            "start": min(events),
            "end": max(events),
            "active_seconds": active_seconds(events),
            "tokens": tokens,
            "languages": langs,
            "models": model_counts,
            "efforts": effort_counts,
            "model_tokens": dict(model_tokens),
            "path": str(OPENCODE_DB),
        })
    return sessions


def claude_session_stats(path: Path):
