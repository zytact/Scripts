#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: blur-image INPUT [OUTPUT] [STRENGTH]

Blur an image with ImageMagick.

Args:
  INPUT       source image path
  OUTPUT      output image path (optional)
  STRENGTH    blur strength/sigma (optional, default: 20)

Examples:
  blur-image wall.png
  blur-image wall.png wall-blur.png
  blur-image wall.png wall-blur-30.png 30

Notes:
  - Uses ImageMagick `magick` if available, else `convert`
  - Blur applied as: -blur 0xSTRENGTH
EOF
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 3 ]]; then
  usage >&2
  exit 1
fi

input=$1
output=${2:-}
strength=${3:-20}

if [[ ! -f "$input" ]]; then
  echo "error: input not found: $input" >&2
  exit 1
fi

if ! [[ "$strength" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
  echo "error: strength must be a number" >&2
  exit 1
fi

if [[ -z "$output" ]]; then
  dir=$(dirname -- "$input")
  file=$(basename -- "$input")
  base=${file%.*}
  ext=${file##*.}
  if [[ "$file" == "$ext" ]]; then
    output="$dir/${file}-blur-${strength}"
  else
    output="$dir/${base}-blur-${strength}.${ext}"
  fi
fi

if command -v magick >/dev/null 2>&1; then
  magick "$input" -blur "0x${strength}" "$output"
elif command -v convert >/dev/null 2>&1; then
  convert "$input" -blur "0x${strength}" "$output"
else
  echo "error: ImageMagick not found (need 'magick' or 'convert')" >&2
  exit 1
fi

echo "$output"
